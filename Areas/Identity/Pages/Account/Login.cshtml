@page
@model MisureRicci.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Accedi";
    Layout = null; // Full screen login
}

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - STEFANO RICCI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --login-bg: #050810;
        }
        body {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--login-bg);
            background-image: 
                radial-gradient(circle at 20% 30%, rgba(212, 175, 55, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(212, 175, 55, 0.05) 0%, transparent 40%);
            overflow: hidden;
            margin: 0;
            font-family: 'Playfair Display', serif;
        }
        .login-container {
            width: 100%;
            max-width: 450px;
            padding: 20px;
            animation: fadeIn 1s cubic-bezier(0.22, 1, 0.36, 1) both;
        }
        .login-card {
            background: rgba(18, 32, 58, 0.7);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: var(--r-lg);
            backdrop-filter: blur(25px) saturate(1.6);
            -webkit-backdrop-filter: blur(25px) saturate(1.6);
            padding: 3.5rem 2.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 30px rgba(212, 175, 55, 0.05);
            position: relative;
        }
        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--sr-gold), transparent);
        }
        .login-logo {
            text-align: center;
            margin-bottom: 3rem;
        }
        .login-logo h1 {
            font-family: 'Cinzel', serif;
            color: var(--sr-gold);
            font-size: 2.2rem;
            font-weight: 700;
            letter-spacing: 0.35em;
            margin: 0;
            text-shadow: 0 0 25px rgba(212, 175, 55, 0.4);
        }
        .login-logo p {
            font-family: 'Cinzel', serif;
            font-size: 0.6rem;
            color: var(--text-2);
            letter-spacing: 0.5em;
            text-transform: uppercase;
            margin-top: 0.75rem;
            opacity: 0.6;
        }
        .form-label {
            font-size: 0.65rem;
            font-weight: 700;
            color: var(--sr-gold-light);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 0.5rem;
        }
        .input-group {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        .input-group-text {
            background: rgba(255, 255, 255, 0.03) !important;
            border-color: rgba(212, 175, 55, 0.15) !important;
            color: var(--sr-gold-dark) !important;
        }
        .form-control {
            background: rgba(255, 255, 255, 0.05) !important;
            border-color: rgba(212, 175, 55, 0.15) !important;
            color: #fff !important;
            font-size: 0.95rem !important;
            padding: 0.75rem 1rem !important;
        }
        .form-control:focus {
            background: rgba(255, 255, 255, 0.08) !important;
            border-color: var(--sr-gold) !important;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15) !important;
        }
        .btn-login {
            background: linear-gradient(135deg, var(--sr-gold-light) 0%, var(--sr-gold) 50%, var(--sr-gold-dark) 100%) !important;
            border: none !important;
            color: var(--sr-navy-deep) !important;
            font-weight: 800 !important;
            letter-spacing: 0.2em !important;
            padding: 1rem !important;
            margin-top: 2rem;
            width: 100%;
            border-radius: var(--r-md) !important;
            transition: all 0.4s var(--ease-out) !important;
            box-shadow: 0 10px 20px -5px rgba(212, 175, 55, 0.3) !important;
        }
        .btn-login:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px -5px rgba(212, 175, 55, 0.5) !important;
            filter: brightness(1.1);
        }
        .form-check-label {
            color: var(--text-2);
            font-size: 0.85rem;
            letter-spacing: 0.05em;
        }
        .form-check-input {
            border-color: rgba(212, 175, 55, 0.3) !important;
            background-color: transparent !important;
        }
        .form-check-input:checked {
            background-color: var(--sr-gold) !important;
            border-color: var(--sr-gold) !important;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .footer-login {
            font-family: 'Cinzel', serif;
            font-size: 0.55rem;
            color: var(--text-3);
            letter-spacing: 0.3em;
            text-transform: uppercase;
            margin-top: 3rem;
            text-align: center;
            opacity: 0.5;
        }
    </style>
</head>
<body class="theme-dark">
    <div class="login-container">
        <div class="login-logo">
            <h1>STEFANO RICCI</h1>
            <p>Misure & Sartoria SaaS</p>
        </div>
        
        <div class="login-card">
            <h2 class="sr-title small text-center mb-4" style="font-size: 0.8rem !important; opacity: 0.9;">Autenticazione Richiesta</h2>
            
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 italic"></div>
                
                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label">Identificativo Staff</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-badge"></i></span>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="staff@stefanoricci.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger small italic d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Password" class="form-label">Chiave d'Accesso</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-key"></i></span>
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger small italic d-block mt-1"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">
                            Ricorda sessione
                        </label>
                    </div>
                </div>

                <button id="login-submit" type="submit" class="btn btn-login">
                    ENTRA NEL SISTEMA <i class="bi bi-chevron-right ms-2" style="font-size: 0.7rem;"></i>
                </button>
            </form>
        </div>
        
        <div class="footer-login">
            &copy; 2026 STEFANO RICCI S.p.A. &middot; Eccellenza Italiana
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
