@page
@model MisureRicci.Areas.Identity.Pages.Account.Manage.ChangePasswordModel

@{
    ViewData["Title"] = "Cambia Password";
}

<div class="page-hero">
    <div>
        <h1 class="page-hero__title">
            <i class="bi bi-key-fill me-2"></i>Cambia Password
        </h1>
        <p class="page-hero__subtitle">Modifica la tua password di accesso al sistema.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success d-flex align-items-center mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @successMessage
    </div>
}

<div class="form-shell" style="max-width: 560px;">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors mb-4"></div>

        <div class="mb-4">
            <label asp-for="Input.OldPassword" class="form-label">Password Attuale</label>
            <input asp-for="Input.OldPassword" type="password" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="Input.OldPassword" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Input.NewPassword" class="form-label">Nuova Password</label>
            <input asp-for="Input.NewPassword" type="password" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Input.NewPassword" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Input.ConfirmPassword" class="form-label">Conferma Nuova Password</label>
            <input asp-for="Input.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
        </div>

        <button type="submit" class="btn btn-gold">
            <i class="bi bi-check-lg me-1"></i>Aggiorna Password
        </button>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-gold ms-2">Annulla</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
