@page
@{
    ViewData["Title"] = "Accesso Negato";
}

<div class="page-hero">
    <div>
        <h1 class="page-hero__title">
            <i class="bi bi-shield-x me-2"></i>Accesso Negato
        </h1>
        <p class="page-hero__subtitle">Non disponi dei permessi necessari per accedere a questa risorsa.</p>
    </div>
</div>

<div class="detail-card" style="max-width: 600px; margin: 2rem auto; text-align: center;">
    <div class="py-4">
        <i class="bi bi-lock-fill" style="font-size: 3rem; color: var(--gold);"></i>
        <p class="mt-3" style="color: var(--text-muted);">
            Se ritieni che si tratti di un errore, contatta l'amministratore del sistema
            per richiedere i permessi appropriati.
        </p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-gold">
        <i class="bi bi-arrow-left me-2"></i>Torna alla Dashboard
    </a>
</div>
