@page
@model MisureRicci.Areas.Identity.Pages.Account.LockoutModel

@{
    ViewData["Title"] = "Account bloccato";
    Layout = null;
}

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Misure Ricci</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="/fonts/fonts.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <script>
        (function () {
            const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            if (theme === 'dark') {
                document.documentElement.classList.add('theme-dark');
            }
        })();
    </script>
</head>
<body class="login-page">
    <div class="login-container">
        <header class="login-brand-panel">
            <div class="login-brand-mark">MR</div>
            <h1 class="login-brand-text">Misure Ricci</h1>
            <div class="login-brand-sub">Tailoring Business Workspace</div>
        </header>

        <div class="login-card card">
            <div class="login-header">
                <h2 class="login-title">
                    <i class="bi bi-shield-lock-fill me-2"></i>Account Bloccato
                </h2>
                <p class="login-subtitle">
                    Il tuo account è stato temporaneamente bloccato a causa di troppi tentativi di accesso non validi.
                </p>
            </div>

            <div class="text-center py-4">
                <div class="mb-3">
                    <i class="bi bi-clock-history" style="font-size: 3rem; color: var(--gold);"></i>
                </div>
                <p style="color: var(--text-muted);">
                    L'account verrà sbloccato automaticamente tra <strong>15 minuti</strong>
                    dall'ultimo tentativo fallito.
                </p>
                <p style="color: var(--text-muted); font-size: 0.85rem;">
                    Se ritieni che si tratti di un errore, contatta l'amministratore del sistema.
                </p>
            </div>

            <a asp-page="./Login" class="btn btn-gold btn-login">
                <i class="bi bi-arrow-left me-2"></i>Torna al Login
            </a>
        </div>

        <footer class="login-footer">
            &copy; 2026 Misure Ricci Design System &middot; Eccellenza Italiana
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
