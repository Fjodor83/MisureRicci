@model MisureRicci.Models.ViewModels.CommessaDetailsViewModel

@{
    ViewData["Title"] = "Dettaglio Commissione";
    var commessa = Model.Commessa;
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Order tracking</span>
        <h1 class="page-title">Commissione @commessa.CommessaCode</h1>
        <p class="page-subtitle">@commessa.Cliente?.Nome @commessa.Cliente?.Cognome - @commessa.TipoCapo</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" asp-route-clienteId="@commessa.ClienteId" class="btn btn-outline-secondary">Elenco Commissioni</a>
        <a asp-controller="Clienti" asp-action="Details" asp-route-id="@commessa.ClienteId" class="btn btn-outline-gold">Torna al Cliente</a>
        <form asp-action="Delete" method="post" class="d-inline">
            <input type="hidden" name="id" value="@commessa.Id" />
            <button type="submit" class="btn btn-danger" data-confirm="Eliminare questa commissione? Le misure resteranno nel profilo cliente.">Elimina Commissione</button>
        </form>
    </div>
</section>

@if (TempData["CommessaError"] is string commessaError && !string.IsNullOrWhiteSpace(commessaError))
{
    <div class="alert alert-warning mb-4">@commessaError</div>
}

<div class="row g-4">
    <div class="col-xl-4">
        <div class="detail-stack">
            <article class="detail-card">
                <div class="detail-card__header">
                    <div>
                        <h2 class="detail-card__title">Informazioni Commissione</h2>
                        <p class="detail-card__subtitle">Stato, tempi e boutique associata.</p>
                    </div>
                </div>
                <div class="detail-list">
                    <div class="detail-row">
                        <span class="detail-row__label">Stato</span>
                        <span class="detail-row__value"><span class="status-pill status-pill--accent">@commessa.Stato</span></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-row__label">Aperta il</span>
                        <span class="detail-row__value">@commessa.DataApertura.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-row__label">Consegna prevista</span>
                        <span class="detail-row__value">@(commessa.DataConsegnaPrevista?.ToString("dd/MM/yyyy") ?? "-")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-row__label">Consegna effettiva</span>
                        <span class="detail-row__value">@(commessa.DataConsegnaEffettiva?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-row__label">Negozio</span>
                        <span class="detail-row__value">@(commessa.Negozio?.Nome ?? "Non assegnato")</span>
                    </div>
                </div>
            </article>

            <article class="form-shell">
                <section class="form-section">
                    <div class="form-section__header">
                        <div>
                            <h2 class="form-section__title">Aggiorna stato</h2>
                            <p class="form-section__text">Transizione guidata con nota operativa opzionale.</p>
                        </div>
                    </div>
                    <form asp-action="AdvanceStato" method="post">
                        <input type="hidden" name="id" value="@commessa.Id" />
                        <div class="mb-3">
                            <label class="form-label">Nuovo stato</label>
                            <select name="nuovoStato" class="form-select">
                                @foreach (var stato in Model.StatiDisponibili)
                                {
                                    <option value="@stato">@stato</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Nota cambio stato</label>
                            <textarea name="note" class="form-control" rows="3" placeholder="Dettagli su avanzamento, prova o consegna..."></textarea>
                        </div>
                        <div class="form-actions mt-3">
                            @if (Model.StatiDisponibili.Any())
                            {
                                <button type="submit" class="btn btn-primary w-100">Salva stato</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-secondary w-100" disabled>Nessuna transizione disponibile</button>
                            }
                        </div>
                    </form>
                </section>

                <section class="form-section">
                    <div class="form-section__header">
                        <div>
                            <h2 class="form-section__title">Aggiungi nota</h2>
                            <p class="form-section__text">Nuove informazioni per laboratorio, boutique o prova cliente.</p>
                        </div>
                    </div>
                    <form asp-action="AddNota" method="post">
                        <input type="hidden" name="id" value="@commessa.Id" />
                        <textarea name="nota" class="form-control" rows="3" placeholder="Nota interna per laboratorio, boutique o prova cliente..."></textarea>
                        <div class="form-actions mt-3">
                            <button type="submit" class="btn btn-outline-gold w-100">Aggiungi nota</button>
                        </div>
                    </form>
                </section>
            </article>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="detail-stack">
            <article class="detail-card">
                <div class="detail-card__header">
                    <div>
                        <h2 class="detail-card__title">Note interne attuali</h2>
                        <p class="detail-card__subtitle">Stato informativo corrente della commessa.</p>
                    </div>
                </div>
                <p class="mb-0 text-preline">
                    @(string.IsNullOrWhiteSpace(commessa.NoteInterne) ? "Nessuna nota operativa." : commessa.NoteInterne)
                </p>
            </article>

            <article class="data-table-card">
                <div class="table-toolbar">
                    <div>
                        <h2 class="detail-card__title">Misure collegate</h2>
                        <div class="toolbar-meta">Record attualmente agganciati alla commessa.</div>
                    </div>
                    @if (Model.HasLinkedMeasureTypeMismatch)
                    {
                        <span class="status-pill status-pill--warning">Tipo capo non corrispondente</span>
                    }
                </div>

                @if (Model.MisureCollegate.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Tipo</th>
                                    <th>Origine</th>
                                    <th class="text-end">Azione</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var misura in Model.MisureCollegate)
                                {
                                    <tr>
                                        <td>@misura.DataCreazione.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td><span class="table-code">@misura.TipoMisura</span></td>
                                        <td>@(misura.IsDynamic ? "Dinamica" : "Legacy")</td>
                                        <td class="text-end">
                                            <form asp-action="UnlinkMisura" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@commessa.Id" />
                                                <input type="hidden" name="misuraClienteId" value="@misura.MisuraClienteId" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary">Scollega</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-state__icon"><i class="bi bi-link-45deg"></i></div>
                        <h3 class="empty-state__title">Nessuna misura collegata</h3>
                        <p class="empty-state__text">La commessa non ha ancora record di misura associati.</p>
                    </div>
                }
            </article>

            @if (Model.MisuraStatus.RequireMisuraCreation)
            {
                <article class="page-surface">
                    <div class="table-toolbar">
                        <div>
                            <h2 class="detail-card__title">Nessuna misura presente</h2>
                            <div class="toolbar-meta">Prima di avanzare la commessa oltre Bozza serve almeno una misura collegata.</div>
                        </div>
                    </div>
                    @if (Model.MeasurementTypes.Any())
                    {
                        <div class="row g-3 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label">Tipo di misura</label>
                                <select id="newMisuraTypeSelect" class="form-select">
                                    @foreach (var t in Model.MeasurementTypes)
                                    {
                                        <option value="@t.Id">@t.Nome</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Unita'</label>
                                <select id="newMisuraUnitSelect" class="form-select">
                                    <option value="@MeasurementUnit.Centimeters">CM</option>
                                    <option value="@MeasurementUnit.Inches">INCH</option>
                                </select>
                            </div>
                            <div class="col-md-4 d-grid">
                                <a id="btnCreaCollegaMisura"
                                   asp-controller="DynamicMeasurements"
                                   asp-action="Create"
                                   asp-route-clienteId="@commessa.ClienteId"
                                   asp-route-typeId="@Model.MeasurementTypes.First().Id"
                                   asp-route-unit="@MeasurementUnit.Centimeters"
                                   asp-route-returnToCommessaId="@commessa.Id"
                                   class="btn btn-primary">
                                    Crea e collega misura
                                </a>
                            </div>
                        </div>

                    }
                    else
                    {
                        <div class="alert alert-danger mb-0">Nessun tipo di misura attivo configurato. Contattare l'amministratore.</div>
                    }
                </article>
            }
            else if (Model.MisuraStatus.HasMisureDisponibili)
            {
                <article class="data-table-card">
                    <div class="table-toolbar">
                        <div>
                            <h2 class="detail-card__title">Misure disponibili del cliente</h2>
                            <div class="toolbar-meta">Scegli il record piu' adatto oppure crea una nuova misura dinamica.</div>
                        </div>
                        @if (Model.MeasurementTypes.Any())
                        {
                            <div class="page-actions">
                                <select id="addMisuraTypeSelect" class="form-select">
                                    @foreach (var t in Model.MeasurementTypes)
                                    {
                                        <option value="@t.Id">@t.Nome</option>
                                    }
                                </select>
                                <select id="addMisuraUnitSelect" class="form-select">
                                    <option value="@MeasurementUnit.Centimeters">CM</option>
                                    <option value="@MeasurementUnit.Inches">INCH</option>
                                </select>
                                <a id="btnAggiungiMisura"
                                   asp-controller="DynamicMeasurements"
                                   asp-action="Create"
                                   asp-route-clienteId="@commessa.ClienteId"
                                   asp-route-typeId="@Model.MeasurementTypes.First().Id"
                                   asp-route-unit="@MeasurementUnit.Centimeters"
                                   asp-route-returnToCommessaId="@commessa.Id"
                                   class="btn btn-outline-gold">
                                    + Nuova misura
                                </a>
                            </div>

                        }
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Tipo</th>
                                    <th>Origine</th>
                                    <th class="text-end">Azione</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var misura in Model.MisureDisponibili)
                                {
                                    <tr class="@(misura.IsRecommended ? "bg-soft-gold" : "")">
                                        <td>@misura.DataCreazione.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <span class="table-code">@misura.TipoMisura</span>
                                            @if (misura.IsRecommended)
                                            {
                                                <span class="badge bg-gold text-navy ms-2">Consigliata</span>
                                            }
                                        </td>
                                        <td>@(misura.IsDynamic ? "Dinamica" : "Legacy")</td>
                                        <td class="text-end">
                                            <form asp-action="LinkMisura" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@commessa.Id" />
                                                <input type="hidden" name="misuraClienteId" value="@misura.MisuraClienteId" />
                                                <button type="submit" class="btn btn-sm @(misura.IsRecommended ? "btn-gold" : "btn-outline-gold")">Collega</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </article>
            }
            else
            {
                <article class="page-surface">
                    <div class="table-toolbar">
                        <div>
                            <h2 class="detail-card__title">Misure disponibili del cliente</h2>
                            <div class="toolbar-meta">Tutte le misure sono gia' state collegate a questa commessa.</div>
                        </div>
                        @if (Model.MeasurementTypes.Any())
                        {
                            <div class="page-actions">
                                <select id="addMisuraTypeSelectFull" class="form-select">
                                    @foreach (var t in Model.MeasurementTypes)
                                    {
                                        <option value="@t.Id">@t.Nome</option>
                                    }
                                </select>
                                <select id="addMisuraUnitSelectFull" class="form-select">
                                    <option value="@MeasurementUnit.Centimeters">CM</option>
                                    <option value="@MeasurementUnit.Inches">INCH</option>
                                </select>
                                <a id="btnAggiungiMisuraFull"
                                   asp-controller="DynamicMeasurements"
                                   asp-action="Create"
                                   asp-route-clienteId="@commessa.ClienteId"
                                   asp-route-typeId="@Model.MeasurementTypes.First().Id"
                                   asp-route-unit="@MeasurementUnit.Centimeters"
                                   asp-route-returnToCommessaId="@commessa.Id"
                                   class="btn btn-outline-gold">
                                    + Nuova misura
                                </a>
                            </div>

                        }
                    </div>
                </article>
            }

            <article class="timeline-card">
                <div class="detail-card__header">
                    <div>
                        <h2 class="detail-card__title">Timeline eventi</h2>
                        <p class="detail-card__subtitle">Tracciamento cronologico di avanzamenti, note e consegne.</p>
                    </div>
                </div>
                @if (commessa.Eventi.Any())
                {
                    <div class="timeline">
                        @foreach (var evento in commessa.Eventi.OrderByDescending(e => e.CreatedAt))
                        {
                            <div class="timeline-item">
                                <div class="timeline-item__meta">@evento.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                <div class="timeline-item__title">@evento.TipoEvento @(evento.NuovoStato.HasValue ? $"- {evento.NuovoStato}" : string.Empty)</div>
                                <div class="timeline-item__text">@evento.Descrizione</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-state__icon"><i class="bi bi-clock-history"></i></div>
                        <h3 class="empty-state__title">Nessun evento registrato</h3>
                        <p class="empty-state__text">La timeline si popolera' con stati, note e consegne man mano che il flusso avanza.</p>
                    </div>
                }
            </article>
        </div>
    </div>
</div>
