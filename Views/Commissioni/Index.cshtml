@model MisureRicci.Models.ViewModels.CommessaIndexViewModel

@{
    ViewData["Title"] = "Commissioni";
    int? clienteId = Model.ClienteId;
    var kpi = Model.Kpi;
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Order flow</span>
        <h1 class="page-title">Commissioni sartoriali</h1>
        <p class="page-subtitle">
            Monitoraggio di stato, consegne e misure collegate con una gerarchia visiva piu' chiara.
        </p>
    </div>
    <div class="page-actions">
        @if (clienteId.HasValue)
        {
            <a asp-action="Create" asp-route-clienteId="@clienteId" class="btn btn-primary">
                <i class="bi bi-journal-plus me-2"></i>Nuova commissione
            </a>
            <a asp-controller="Clienti" asp-action="Details" asp-route-id="@clienteId" class="btn btn-outline-secondary">Torna al cliente</a>
        }
        else
        {
            <a asp-controller="Clienti" asp-action="Index" class="btn btn-outline-secondary">Seleziona cliente</a>
        }
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <div class="metric-label">Totale commissioni</div>
        <div class="metric-value">@(kpi?.Totale ?? 0)</div>
        <div class="metric-meta">Vista completa del backlog ordini.</div>
    </article>
    <article class="metric-card">
        <div class="metric-label">In corso</div>
        <div class="metric-value">@(kpi?.InCorso ?? 0)</div>
        <div class="metric-meta">Ordini che richiedono avanzamento o note operative.</div>
    </article>
    <article class="metric-card">
        <div class="metric-label">Consegnate</div>
        <div class="metric-value">@(kpi?.Consegnate ?? 0)</div>
        <div class="metric-meta">Flusso chiuso correttamente e tracciato.</div>
    </article>
    <article class="metric-card">
        <div class="metric-label">In ritardo</div>
        <div class="metric-value text-danger">@(kpi?.InRitardo ?? 0)</div>
        <div class="metric-meta">Ordini che richiedono attenzione immediata.</div>
    </article>
</section>

<section class="data-table-card">
    <div class="table-toolbar">
        <div>
            <h2 class="detail-card__title">Lista commissioni</h2>
            <div class="toolbar-meta">
                @(clienteId.HasValue ? "Vista filtrata sul cliente selezionato." : "Vista complessiva delle commissioni accessibili.")
            </div>
        </div>
        <span class="toolbar-chip">@Model.Items.Count record</span>
    </div>

    @if (Model.Items.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Codice</th>
                        <th>Cliente</th>
                        <th>Tipo capo</th>
                        <th>Stato</th>
                        <th>Consegna prevista</th>
                        <th class="text-end">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><span class="table-code">@item.CommessaCode</span></td>
                            <td>@item.Cliente?.Nome @item.Cliente?.Cognome</td>
                            <td>@item.TipoCapo</td>
                            <td><span class="status-pill status-pill--accent">@item.Stato</span></td>
                            <td>@(item.DataConsegnaPrevista?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-gold">Dettaglio</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-4">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-clienteId="@clienteId" asp-route-page="@(Model.CurrentPage - 1)">Precedente</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-clienteId="@clienteId" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-clienteId="@clienteId" asp-route-page="@(Model.CurrentPage + 1)">Successiva</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state__icon"><i class="bi bi-journal-x"></i></div>
            <h3 class="empty-state__title">Nessuna commissione presente</h3>
            <p class="empty-state__text">Apri una nuova commissione oppure seleziona un cliente per avviare il flusso ordine.</p>
            @if (clienteId.HasValue)
            {
                <a asp-action="Create" asp-route-clienteId="@clienteId" class="btn btn-primary">Apri commissione</a>
            }
        </div>
    }
</section>
