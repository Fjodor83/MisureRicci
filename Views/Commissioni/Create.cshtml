@model MisureRicci.Models.ViewModels.CommessaCreateViewModel

@{
    ViewData["Title"] = "Nuova Commissione";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Order opening</span>
        <h1 class="page-title">Apri Nuova Commissione</h1>
        <p class="page-subtitle">Cliente: <strong>@Model.ClienteNome</strong>. Definisci capo, tempi e misure da collegare subito.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Clienti" asp-action="Details" asp-route-id="@Model.ClienteId" class="btn btn-outline-secondary">Torna al cliente</a>
    </div>
</section>

<form asp-action="Create" method="post" class="form-shell">
    <input type="hidden" asp-for="ClienteId" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <section class="form-section">
        <div class="form-section__header">
            <div>
                <h2 class="form-section__title">Impostazioni Commissione</h2>
                <p class="form-section__text">Descrivi il capo e definisci il perimetro operativo iniziale.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="TipoCapo" class="form-label"></label>
                @if (Model.TipoCapiDisponibili.Any())
                {
                    <select asp-for="TipoCapo" class="form-select" asp-items="new SelectList(Model.TipoCapiDisponibili, nameof(MeasurementType.Nome), nameof(MeasurementType.Nome))">
                        <option value=""> Seleziona  Capo </option>
                    </select>
                }
                else
                {
                    <div class="alert alert-warning">
                        <p class="mb-0">Nessun tipo di capo disponibile nel catalogo. <a asp-controller="AdminMeasurementTypes" asp-action="CreateType">Aggiungine uno</a>.</p>
                    </div>
                }
                <span asp-validation-for="TipoCapo" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Tessuto" class="form-label"></label>
                <input asp-for="Tessuto" class="form-control" placeholder="Es. Lana Super 150's" />
                <span asp-validation-for="Tessuto" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Collezione" class="form-label"></label>
                <input asp-for="Collezione" class="form-control" placeholder="Es. Primavera Estate 2026" />
                <span asp-validation-for="Collezione" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="DataConsegnaPrevista" class="form-label"></label>
                <input asp-for="DataConsegnaPrevista" class="form-control" />
                <span asp-validation-for="DataConsegnaPrevista" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="NoteInterne" class="form-label"></label>
                <textarea asp-for="NoteInterne"
                          class="form-control"
                          rows="4"
                          placeholder="Indicazioni operative, preferenze vestibilita', urgenze..."></textarea>
                <span asp-validation-for="NoteInterne" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <div class="form-section__header">
            <div>
                <h2 class="form-section__title">Misure da collegare</h2>
                <p class="form-section__text">Seleziona le misure gia' disponibili da agganciare subito alla nuova commissione.</p>
            </div>
        </div>

        @if (Model.MisureDisponibili.Any())
        {
            <div class="selection-grid">
                @foreach (var misura in Model.MisureDisponibili)
                {
                    <label class="selection-card d-flex align-items-start gap-3">
                        <input class="form-check-input mt-1"
                               type="checkbox"
                               name="SelectedMisuraIds"
                               value="@misura.MisuraClienteId"
                               id="misura_@misura.MisuraClienteId">
                        <span>
                            <span class="selection-card__title d-block">@misura.TipoMisura</span>
                            <span class="selection-card__meta d-block">@misura.DataCreazione.ToString("dd/MM/yyyy HH:mm")</span>
                            @if (!string.IsNullOrEmpty(misura.Note))
                            {
                                <span class="selection-card__meta d-block">@misura.Note</span>
                            }
                        </span>
                    </label>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state__icon"><i class="bi bi-rulers"></i></div>
                <h3 class="empty-state__title">Nessuna misura disponibile</h3>
                <p class="empty-state__text">Potrai crearla e collegarla subito dopo l'apertura della commissione.</p>
            </div>
        }
    </section>

    <div class="form-actions">
        <a asp-controller="Clienti" asp-action="Details" asp-route-id="@Model.ClienteId" class="btn btn-outline-secondary">Annulla</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle me-2"></i>Apri commissione
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
