@model MisureRicci.Models.ViewModels.MeasurementTypeManageViewModel

@{
    ViewData["Title"] = "Campi Tipologia";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Admin configuration</span>
        <h1 class="page-title">@Model.Type.Nome</h1>
        <p class="page-subtitle">Definizione dinamica dei campi per la tipologia selezionata.</p>
    </div>
    <div class="page-actions">
        <a asp-action="CreateField" asp-route-typeId="@Model.Type.Id" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Nuovo campo
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">Torna alle tipologie</a>
    </div>
</section>

<section class="data-table-card">
    <div class="table-toolbar">
        <div>
            <h2 class="detail-card__title">Struttura campi</h2>
            <div class="toolbar-meta">Ordine, gruppo, template e stato dei campi configurati.</div>
        </div>
        <span class="toolbar-chip">@Model.Fields.Count campo/i</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Gruppo</th>
                    <th>Ordine</th>
                    <th>Campo</th>
                    <th>Etichetta</th>
                    <th>Tipo</th>
                    <th>Template</th>
                    <th>Req</th>
                    <th>Stato</th>
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Fields.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">Nessun campo configurato</td>
                    </tr>
                }
                else
                {
                    @foreach (var field in Model.Fields.OrderBy(f => f.OrdineGruppo).ThenBy(f => f.Gruppo).ThenBy(f => f.Ordine).ThenBy(f => f.Etichetta))
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@(string.IsNullOrWhiteSpace(field.Gruppo) ? "Generale" : field.Gruppo)</div>
                                <div class="text-muted small">Sezione @field.OrdineGruppo</div>
                            </td>
                            <td>@field.Ordine</td>
                            <td class="fw-bold">@field.NomeCampo</td>
                            <td>
                                <div>@field.Etichetta @(string.IsNullOrWhiteSpace(field.UnitaMisura) ? "" : $"({field.UnitaMisura})")</div>
                                @if (!string.IsNullOrWhiteSpace(field.HelpText))
                                {
                                    <div class="text-muted small">@field.HelpText</div>
                                }
                            </td>
                            <td>@field.TipoDato</td>
                            <td>@field.Template</td>
                            <td><span class="status-pill @(field.Obbligatorio ? "status-pill--warning" : "status-pill--neutral")">@(field.Obbligatorio ? "Si" : "No")</span></td>
                            <td><span class="status-pill @(field.IsActive ? "status-pill--success" : "status-pill--neutral")">@(field.IsActive ? "Attivo" : "Off")</span></td>
                            <td class="text-end">
                                <div class="page-actions justify-content-end">
                                    <a asp-action="EditField" asp-route-id="@field.Id" class="btn btn-sm btn-outline-secondary">Modifica</a>
                                    <form asp-action="DeleteField" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@field.Id" />
                                        <input type="hidden" name="typeId" value="@Model.Type.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" data-confirm="Eliminare questo campo?">Elimina</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
