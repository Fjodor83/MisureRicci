@model MisureRicci.Models.MeasurementType

@{
    ViewData["Title"] = "Nuova Tipologia";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Admin configuration</span>
        <h1 class="page-title">Nuova tipologia misura</h1>
        <p class="page-subtitle">Definisci nome, descrizione e stato iniziale della nuova tipologia dinamica.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</section>

<form asp-action="CreateType" method="post" class="form-shell" enctype="multipart/form-data">
    <section class="form-section">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Descrizione" class="form-label"></label>
            <textarea asp-for="Descrizione" class="form-control"></textarea>
            <span asp-validation-for="Descrizione" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ImageUpload" class="form-label">Immagine di Riferimento (Opzionale)</label>
            <input asp-for="ImageUpload" type="file" class="form-control" accept="image/*" />
            <span asp-validation-for="ImageUpload" class="text-danger"></span>
            <div class="form-text text-muted">Carica una foto che servir&agrave; come guida visiva per la compilazione (es. JPEG, PNG max 2MB).</div>
        </div>

        <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>
    </section>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Salva tipologia</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
