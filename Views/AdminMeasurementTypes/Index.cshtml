@model IEnumerable<MisureRicci.Models.MeasurementType>

@{
    ViewData["Title"] = "Tipologie Misure Dinamiche";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Admin configuration</span>
        <h1 class="page-title">Tipologie dinamiche</h1>
        <p class="page-subtitle">Gestisci categorie, stato attivo e struttura dei form dinamici.</p>
    </div>
    <div class="page-actions">
        <a asp-action="CreateType" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Nuova tipologia
        </a>
    </div>
</section>

<section class="data-table-card">
    <div class="table-toolbar">
        <div>
            <h2 class="detail-card__title">Catalogo tipologie</h2>
            <div class="toolbar-meta">Elenco delle tipologie disponibili nel sistema.</div>
        </div>
        <span class="toolbar-chip">@Model.Count() tipologie</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Descrizione</th>
                    <th>Stato</th>
                    <th>Sistema</th>
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Nessuna tipologia configurata</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Nome</td>
                            <td class="text-muted">@item.Descrizione</td>
                            <td><span class="status-pill @(item.IsActive ? "status-pill--success" : "status-pill--neutral")">@(item.IsActive ? "Attiva" : "Disattiva")</span></td>
                            <td><span class="status-pill @(item.IsSystem ? "status-pill--warning" : "status-pill--neutral")">@(item.IsSystem ? "System" : "Custom")</span></td>
                            <td class="text-end">
                                <div class="page-actions justify-content-end">
                                    <a asp-action="Fields" asp-route-typeId="@item.Id" class="btn btn-sm btn-outline-gold">Campi</a>
                                    <a asp-action="EditType" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Modifica</a>
                                    @if (!item.IsSystem)
                                    {
                                        <form asp-action="DeleteType" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger" data-confirm="Eliminare questa tipologia e tutti i campi collegati?">Elimina</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
