@model IEnumerable<MisureRicci.Models.MeasurementType>

@{
    ViewData["Title"] = "Tipologie Misure Dinamiche";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">TIPOLOGIE MISURE</h1>
        <p class="page-subtitle mb-0">L'amministratore gestisce categorie e struttura campi dinamici.</p>
    </div>
    <a asp-action="CreateType" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Nuova Tipologia</a>
</div>

<div class="card card-static p-3">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Descrizione</th>
                    <th>Stato</th>
                    <th>Sistema</th>
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Nessuna tipologia configurata</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Nome</td>
                            <td class="text-muted">@item.Descrizione</td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">@(item.IsActive ? "Attiva" : "Disattiva")</span>
                            </td>
                            <td>
                                <span class="badge @(item.IsSystem ? "bg-warning text-dark" : "bg-secondary")">@(item.IsSystem ? "System" : "Custom")</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Fields" asp-route-typeId="@item.Id" class="btn btn-sm btn-outline-gold me-1">Campi</a>
                                <a asp-action="EditType" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">Modifica</a>
                                @if (!item.IsSystem)
                                {
                                    <form asp-action="DeleteType" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Eliminare questa tipologia e tutti i campi collegati?');">Elimina</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
