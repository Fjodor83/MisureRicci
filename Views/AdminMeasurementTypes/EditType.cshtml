@model MisureRicci.Models.MeasurementType

@{
    ViewData["Title"] = "Modifica Tipologia";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Admin configuration</span>
        <h1 class="page-title">Modifica tipologia</h1>
        <p class="page-subtitle">Aggiorna nome, descrizione e stato della tipologia dinamica selezionata.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Torna alle tipologie</a>
    </div>
</section>

<form asp-action="EditType" method="post" class="form-shell">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="IsSystem" />
    <input type="hidden" asp-for="CreatedAt" />

    <section class="form-section">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Descrizione" class="form-label"></label>
            <textarea asp-for="Descrizione" class="form-control"></textarea>
            <span asp-validation-for="Descrizione" class="text-danger"></span>
        </div>

        <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>
    </section>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Salva modifiche</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
