@model MisureRicci.Models.MeasurementType

@{
    ViewData["Title"] = "Modifica Tipologia";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Admin configuration</span>
        <h1 class="page-title">Modifica tipologia</h1>
        <p class="page-subtitle">Aggiorna nome, descrizione e stato della tipologia dinamica selezionata.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Torna alle tipologie</a>
    </div>
</section>

<form asp-action="EditType" method="post" class="form-shell" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />

    <section class="form-section">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Descrizione" class="form-label"></label>
            <textarea asp-for="Descrizione" class="form-control"></textarea>
            <span asp-validation-for="Descrizione" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ImageUpload" class="form-label">Immagine di Riferimento (Opzionale)</label>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-2">
                    <img src="@Model.ImageUrl" alt="Modello misure" class="img-thumbnail" style="max-height: 120px;" />
                    <div class="form-text mt-1 text-muted">Caricando un nuovo file, l'immagine attuale verr&agrave; sostituita.</div>
                </div>
            }
            <input asp-for="ImageUpload" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
            <span asp-validation-for="ImageUpload" class="text-danger"></span>
            @if (string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="form-text text-muted">Carica una foto JPG, PNG o WEBP fino a 5 MB. Il file viene validato lato server e salvato in area protetta.</div>
            }
        </div>

        <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>
    </section>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Salva modifiche</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
