@model MisureRicci.Models.DynamicMeasurementRecord

@{
    ViewData["Title"] = "Dettaglio Misura Dinamica";
    var groupedValues = Model.Values
        .OrderBy(v => v.MeasurementFieldDefinition?.OrdineGruppo)
        .ThenBy(v => v.MeasurementFieldDefinition?.Gruppo)
        .ThenBy(v => v.MeasurementFieldDefinition?.Ordine)
        .ThenBy(v => v.MeasurementFieldDefinition?.Etichetta)
        .GroupBy(v => new
        {
            Ordine = v.MeasurementFieldDefinition?.OrdineGruppo ?? 0,
            Nome = string.IsNullOrWhiteSpace(v.MeasurementFieldDefinition?.Gruppo) ? "Generale" : v.MeasurementFieldDefinition!.Gruppo!
        })
        .ToList();
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Dynamic measurement</span>
        <h1 class="page-title">@Model.MeasurementType?.Nome</h1>
        <p class="page-subtitle">Cliente: <strong>@Model.Cliente?.Nome @Model.Cliente?.Cognome</strong></p>
    </div>
    <div class="page-actions">
        <span class="toolbar-chip">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifica</a>
        <form asp-action="Delete" method="post" class="d-inline">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="clienteId" value="@Model.ClienteId" />
            <button type="submit" class="btn btn-danger" data-confirm="Eliminare questa misura dinamica?">Elimina</button>
        </form>
    </div>
</section>

<div class="row">
    <div class="@(!string.IsNullOrEmpty(Model.MeasurementType?.ImageUrl) ? "col-lg-6" : "col-12")">
@foreach (var group in groupedValues)
{
    <section class="data-table-card mb-4">
        <div class="table-toolbar">
            <div>
                <h2 class="detail-card__title">@group.Key.Nome</h2>
                <div class="toolbar-meta">Gruppo @group.Key.Ordine</div>
            </div>
            <span class="toolbar-chip">@group.Count() valori</span>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Campo</th>
                        <th>Valore</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var value in group)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@value.MeasurementFieldDefinition?.Etichetta</div>
                                @if (!string.IsNullOrWhiteSpace(value.MeasurementFieldDefinition?.HelpText))
                                {
                                    <div class="text-muted small">@value.MeasurementFieldDefinition?.HelpText</div>
                                }
                            </td>
                            <td>@value.Valore @(string.IsNullOrWhiteSpace(value.MeasurementFieldDefinition?.UnitaMisura) ? "" : value.MeasurementFieldDefinition?.UnitaMisura)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}
    </div>

    @if (!string.IsNullOrEmpty(Model.MeasurementType?.ImageUrl))
    {
        <div class="col-lg-6 mt-4 mt-lg-0">
            <div class="sticky-top" style="top: 100px;">
                <div class="card card-static shadow-sm border-0">
                    <div class="card-header bg-transparent border-bottom-0 pb-0 pt-4 px-4 text-center">
                        <h3 class="card-title h6 rounded bg-gold text-white d-inline-block py-2 px-4 mb-0 shadow-sm"><i class="bi bi-image me-2"></i>Modello di Riferimento</h3>
                    </div>
                    <div class="card-body p-4 text-center">
                        <a href="#" data-bs-toggle="modal" data-bs-target="#imageZoomModal">
                            <img src="@Model.MeasurementType.ImageUrl" class="img-fluid rounded shadow-sm" alt="Modello di misurazione" style="max-height: 65vh; object-fit: contain; width: 100%; border: 1px solid var(--border); cursor: zoom-in;" />
                        </a>
                        <div class="form-text mt-2"><i class="bi bi-zoom-in"></i> Clicca sulla foto per ingrandirla</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(Model.MeasurementType?.ImageUrl))
{
<div class="modal fade" id="imageZoomModal" tabindex="-1" aria-labelledby="imageZoomModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content border-0" style="background-color: transparent;">
      <div class="modal-header border-0 pb-0 justify-content-end p-2 position-absolute w-100" style="z-index: 10;">
        <button type="button" class="btn-close btn-close-white fs-4 rounded-circle p-2" style="background-color: rgba(0,0,0,0.5);" data-bs-dismiss="modal" aria-label="Chiudi"></button>
      </div>
      <div class="modal-body text-center p-0">
        <img src="@Model.MeasurementType.ImageUrl" class="img-fluid rounded shadow-lg" alt="Modello Ingrandito" style="max-height: 90vh; object-fit: contain; width: 100%;" />
      </div>
    </div>
  </div>
</div>
}

<div class="form-actions">
    <a asp-controller="Clienti" asp-action="Details" asp-route-id="@Model.ClienteId" class="btn btn-outline-secondary">Torna al cliente</a>
</div>
