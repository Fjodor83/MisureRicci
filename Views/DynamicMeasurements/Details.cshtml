@model MisureRicci.Models.DynamicMeasurementRecord

@{
    ViewData["Title"] = "Dettaglio Misura Dinamica";
    var groupedValues = Model.Values
        .OrderBy(v => v.MeasurementFieldDefinition?.OrdineGruppo)
        .ThenBy(v => v.MeasurementFieldDefinition?.Gruppo)
        .ThenBy(v => v.MeasurementFieldDefinition?.Ordine)
        .ThenBy(v => v.MeasurementFieldDefinition?.Etichetta)
        .GroupBy(v => new
        {
            Ordine = v.MeasurementFieldDefinition?.OrdineGruppo ?? 0,
            Nome = string.IsNullOrWhiteSpace(v.MeasurementFieldDefinition?.Gruppo) ? "Generale" : v.MeasurementFieldDefinition!.Gruppo!
        })
        .ToList();
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">DETTAGLIO @Model.MeasurementType?.Nome?.ToUpper()</h1>
        <p class="page-subtitle mb-0">Cliente: <strong>@Model.Cliente?.Nome @Model.Cliente?.Cognome</strong></p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <div class="text-muted small me-2">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-gold">Modifica</a>
        <form asp-action="Delete" method="post" class="d-inline">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="clienteId" value="@Model.ClienteId" />
            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Eliminare questa misura dinamica?');">Elimina</button>
        </form>
    </div>
</div>

@foreach (var group in groupedValues)
{
    <div class="card p-4 mb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="sr-title small mb-0">@group.Key.Nome</h3>
            <span class="badge rounded-pill" style="background: rgba(212, 175, 55, 0.08); color: var(--sr-gold);">@group.Count() VALORI</span>
        </div>
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Campo</th>
                        <th>Valore</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var value in group)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@value.MeasurementFieldDefinition?.Etichetta</div>
                            @if (!string.IsNullOrWhiteSpace(value.MeasurementFieldDefinition?.HelpText))
                            {
                                <div class="text-muted small">@value.MeasurementFieldDefinition?.HelpText</div>
                            }
                        </td>
                        <td>@value.Valore @(string.IsNullOrWhiteSpace(value.MeasurementFieldDefinition?.UnitaMisura) ? "" : value.MeasurementFieldDefinition?.UnitaMisura)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="mt-4">
    <a asp-controller="Clienti" asp-action="Details" asp-route-id="@Model.ClienteId" class="btn btn-outline-secondary">Torna al Cliente</a>
</div>
