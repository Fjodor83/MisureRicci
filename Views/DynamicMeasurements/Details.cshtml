@model MisureRicci.Models.DynamicMeasurementRecord

@{
    ViewData["Title"] = "Dettaglio Misura Dinamica";
    var groupedValues = Model.Values
        .OrderBy(v => v.MeasurementFieldDefinition?.OrdineGruppo)
        .ThenBy(v => v.MeasurementFieldDefinition?.Gruppo)
        .ThenBy(v => v.MeasurementFieldDefinition?.Ordine)
        .ThenBy(v => v.MeasurementFieldDefinition?.Etichetta)
        .GroupBy(v => new
        {
            Ordine = v.MeasurementFieldDefinition?.OrdineGruppo ?? 0,
            Nome = string.IsNullOrWhiteSpace(v.MeasurementFieldDefinition?.Gruppo) ? "Generale" : v.MeasurementFieldDefinition!.Gruppo!
        })
        .ToList();
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Dynamic measurement</span>
        <h1 class="page-title">@Model.MeasurementType?.Nome</h1>
        <p class="page-subtitle">Cliente: <strong>@Model.Cliente?.Nome @Model.Cliente?.Cognome</strong></p>
    </div>
    <div class="page-actions">
        <span class="toolbar-chip">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifica</a>
        <form asp-action="Delete" method="post" class="d-inline">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="clienteId" value="@Model.ClienteId" />
            <button type="submit" class="btn btn-danger" onclick="return confirm('Eliminare questa misura dinamica?');">Elimina</button>
        </form>
    </div>
</section>

@foreach (var group in groupedValues)
{
    <section class="data-table-card mb-4">
        <div class="table-toolbar">
            <div>
                <h2 class="detail-card__title">@group.Key.Nome</h2>
                <div class="toolbar-meta">Gruppo @group.Key.Ordine</div>
            </div>
            <span class="toolbar-chip">@group.Count() valori</span>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Campo</th>
                        <th>Valore</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var value in group)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@value.MeasurementFieldDefinition?.Etichetta</div>
                                @if (!string.IsNullOrWhiteSpace(value.MeasurementFieldDefinition?.HelpText))
                                {
                                    <div class="text-muted small">@value.MeasurementFieldDefinition?.HelpText</div>
                                }
                            </td>
                            <td>@value.Valore @(string.IsNullOrWhiteSpace(value.MeasurementFieldDefinition?.UnitaMisura) ? "" : value.MeasurementFieldDefinition?.UnitaMisura)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

<div class="form-actions">
    <a asp-controller="Clienti" asp-action="Details" asp-route-id="@Model.ClienteId" class="btn btn-outline-secondary">Torna al cliente</a>
</div>
