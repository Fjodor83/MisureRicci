@using System.Collections.Generic
@model MisureRicci.Models.ViewModels.DynamicMeasurementCreateViewModel

@{
    ViewData["Title"] = "Nuova Misura Dinamica";
    var selectedUnitLabel = MeasurementUnitHelper.ToShortLabel(Model.SelectedUnit);
    var backAction = Model.ReturnToCommessaId.HasValue ? "Details" : "Index";
    var backController = Model.ReturnToCommessaId.HasValue ? "Commissioni" : "Measurements";
    var backRouteValues = Model.ReturnToCommessaId.HasValue
        ? new Dictionary<string, string> { ["id"] = Model.ReturnToCommessaId.Value.ToString() }
        : new Dictionary<string, string> { ["clienteId"] = Model.ClienteId.ToString() };
    var groupedFields = Model.Fields
        .OrderBy(f => f.OrdineGruppo)
        .ThenBy(f => f.Gruppo)
        .ThenBy(f => f.Ordine)
        .ThenBy(f => f.Etichetta)
        .GroupBy(f => new { f.OrdineGruppo, Nome = string.IsNullOrWhiteSpace(f.Gruppo) ? "Generale" : f.Gruppo! })
        .ToList();
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Dynamic measurement</span>
        <h1 class="page-title">@Model.TipoNome</h1>
        <p class="page-subtitle">Cliente: <strong>@Model.ClienteNome</strong>. Compila i campi usando il layout guidato per gruppi e l'unita' selezionata.</p>
    </div>
    <div class="page-actions">
        <span class="toolbar-chip">Unita' @selectedUnitLabel</span>
        <a asp-controller="@backController" asp-action="@backAction" asp-all-route-data="backRouteValues" class="btn btn-outline-secondary">@(Model.ReturnToCommessaId.HasValue ? "Torna alla commessa" : "Torna alle tipologie")</a>
    </div>
</section>

<div class="row">
    <div class="@(!string.IsNullOrEmpty(Model.TypeImageUrl) ? "col-lg-6" : "col-12")">
        <form asp-action="@(Model.RecordId == 0 ? "Create" : "Edit")" method="post" class="form-shell">
    <input type="hidden" asp-for="RecordId" />
    <input type="hidden" asp-for="ClienteId" />
    <input type="hidden" asp-for="MeasurementTypeId" />
    <input type="hidden" asp-for="ReturnToCommessaId" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <section class="form-section mb-4">
        <div class="form-section__header">
            <div>
                <h2 class="form-section__title">Unita' di rilevazione</h2>
                <p class="form-section__text">La scelta si applica ai campi numerici in lunghezza del form corrente.</p>
            </div>
        </div>
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label asp-for="SelectedUnit" class="form-label">Unita'</label>
                <select asp-for="SelectedUnit"
                        class="form-select"
                        id="measurementUnitSelect"
                        data-current-unit="@Model.SelectedUnit">
                    <option value="@MeasurementUnit.Centimeters">CM</option>
                    <option value="@MeasurementUnit.Inches">INCH</option>
                </select>
            </div>
            <div class="col-md-8">
                <div class="form-text mb-2">Se cambi unita', i valori numerici compatibili vengono convertiti automaticamente.</div>
            </div>
        </div>
    </section>

    @if (!Model.Fields.Any())
    {
        <div class="empty-state">
            <div class="empty-state__icon"><i class="bi bi-sliders2"></i></div>
            <h3 class="empty-state__title">Tipologia senza campi attivi</h3>
            <p class="empty-state__text">Configura i campi da area amministrativa prima di registrare questa misura.</p>
        </div>
    }
    else
    {
        @for (int i = 0; i < Model.Fields.Count; i++)
        {
            <input type="hidden" asp-for="Fields[i].FieldDefinitionId" />
            <input type="hidden" asp-for="Fields[i].NomeCampo" />
            <input type="hidden" asp-for="Fields[i].Etichetta" />
            <input type="hidden" asp-for="Fields[i].Gruppo" />
            <input type="hidden" asp-for="Fields[i].OrdineGruppo" />
            <input type="hidden" asp-for="Fields[i].TipoDato" />
            <input type="hidden" asp-for="Fields[i].Template" />
            <input type="hidden" asp-for="Fields[i].UnitaMisura" />
            <input type="hidden" asp-for="Fields[i].Placeholder" />
            <input type="hidden" asp-for="Fields[i].HelpText" />
            <input type="hidden" asp-for="Fields[i].Obbligatorio" />
            <input type="hidden" asp-for="Fields[i].Ordine" />
        }

        @foreach (var group in groupedFields)
        {
            <section class="page-surface dynamic-group">
                <div class="table-toolbar">
                    <div>
                        <h2 class="detail-card__title">@group.Key.Nome</h2>
                        <div class="toolbar-meta">Gruppo @group.Key.OrdineGruppo</div>
                    </div>
                    <span class="toolbar-chip">@group.Count() campi</span>
                </div>

                <div class="row g-3">
                    @foreach (var field in group)
                    {
                        var fieldIndex = Model.Fields.FindIndex(x => x.FieldDefinitionId == field.FieldDefinitionId);
                        var supportsUnitConversion = MeasurementUnitHelper.SupportsConversion(Model.Fields[fieldIndex].TipoDato, Model.Fields[fieldIndex].UnitaMisura);
                        var displayUnit = MeasurementUnitHelper.GetFieldUnitLabel(Model.Fields[fieldIndex].UnitaMisura, Model.Fields[fieldIndex].TipoDato, Model.SelectedUnit);
                        var isStructure = field.Template == MisureRicci.Models.DynamicFieldTemplate.SectionHeader
                            || field.Template == MisureRicci.Models.DynamicFieldTemplate.Divider
                            || field.Template == MisureRicci.Models.DynamicFieldTemplate.AlertNote;
                        var isNotesField = field.Template == MisureRicci.Models.DynamicFieldTemplate.Notes;
                        var hasHelpText = !string.IsNullOrWhiteSpace(Model.Fields[fieldIndex].HelpText);
                        var fieldHelpId = hasHelpText ? $"field-help-{field.FieldDefinitionId}" : null;
                        var wrapperClass = "col-md-6";

                        if (isStructure)
                        {
                            wrapperClass = "col-12";
                        }

                        var shellClass = "dynamic-field-shell";

                        if (supportsUnitConversion)
                        {
                            shellClass += " dynamic-field-shell--emphasis";
                        }

                        if (isNotesField)
                        {
                            shellClass += " dynamic-field-shell--notes";
                        }

                        <div class="@wrapperClass">
                            @if (field.Template == MisureRicci.Models.DynamicFieldTemplate.SectionHeader)
                            {
                                <div class="dynamic-structure-header">
                                    <h3 class="sr-title small mb-1">@Model.Fields[fieldIndex].Etichetta</h3>
                                    @if (!string.IsNullOrWhiteSpace(Model.Fields[fieldIndex].HelpText))
                                    {
                                        <div class="dynamic-field-help">@Model.Fields[fieldIndex].HelpText</div>
                                    }
                                </div>
                            }
                            else if (field.Template == MisureRicci.Models.DynamicFieldTemplate.Divider)
                            {
                                <hr class="dynamic-structure-divider" />
                            }
                            else if (field.Template == MisureRicci.Models.DynamicFieldTemplate.AlertNote)
                            {
                                <div class="dynamic-structure-alert alert alert-warning">
                                    <div class="fw-bold">@Model.Fields[fieldIndex].Etichetta</div>
                                    @if (!string.IsNullOrWhiteSpace(Model.Fields[fieldIndex].HelpText))
                                    {
                                        <div class="dynamic-field-help">@Model.Fields[fieldIndex].HelpText</div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="@shellClass">
                                    <div class="dynamic-field-shell__header">
                                        <div class="dynamic-field-shell__title-block">
                                            <label asp-for="Fields[fieldIndex].Valore" class="dynamic-field-shell__label">
                                                @Model.Fields[fieldIndex].Etichetta
                                            </label>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(displayUnit) || Model.Fields[fieldIndex].Obbligatorio)
                                        {
                                            <div class="dynamic-field-shell__chips">
                                                @if (!string.IsNullOrWhiteSpace(displayUnit))
                                                {
                                                    <span class="dynamic-field-chip dynamic-field-chip--unit"
                                                          data-measurement-unit-label="true"
                                                          data-convertible-length="@(supportsUnitConversion ? "true" : "false")">
                                                        @displayUnit
                                                    </span>
                                                }
                                                @if (Model.Fields[fieldIndex].Obbligatorio)
                                                {
                                                    <span class="dynamic-field-chip dynamic-field-chip--required">Richiesto</span>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="dynamic-field-shell__control">
                                        @switch (Model.Fields[fieldIndex].TipoDato)
                                        {
                                            case MisureRicci.Models.DynamicFieldType.Number:
                                                <input asp-for="Fields[fieldIndex].Valore"
                                                       type="number"
                                                       step="1"
                                                       class="form-control dynamic-field-input dynamic-field-input--measure text-center"
                                                       placeholder="@Model.Fields[fieldIndex].Placeholder"
                                                       aria-describedby="@fieldHelpId"
                                                       data-measurement-field="true"
                                                       data-convertible-length="@(supportsUnitConversion ? "true" : "false")" />
                                                break;
                                            case MisureRicci.Models.DynamicFieldType.Decimal:
                                                <input asp-for="Fields[fieldIndex].Valore"
                                                       type="number"
                                                       step="0.01"
                                                       class="form-control dynamic-field-input dynamic-field-input--measure text-center"
                                                       placeholder="@Model.Fields[fieldIndex].Placeholder"
                                                       aria-describedby="@fieldHelpId"
                                                       data-measurement-field="true"
                                                       data-convertible-length="@(supportsUnitConversion ? "true" : "false")" />
                                                break;
                                            case MisureRicci.Models.DynamicFieldType.Date:
                                                <input asp-for="Fields[fieldIndex].Valore"
                                                       type="date"
                                                       class="form-control dynamic-field-input"
                                                       aria-describedby="@fieldHelpId" />
                                                break;
                                            case MisureRicci.Models.DynamicFieldType.Boolean:
                                                <select asp-for="Fields[fieldIndex].Valore"
                                                        class="form-select dynamic-field-input"
                                                        aria-describedby="@fieldHelpId">
                                                    <option value="">Seleziona...</option>
                                                    <option value="true">Si</option>
                                                    <option value="false">No</option>
                                                </select>
                                                break;
                                            default:
                                                if (isNotesField)
                                                {
                                                    <textarea asp-for="Fields[fieldIndex].Valore"
                                                              rows="4"
                                                              class="form-control dynamic-field-input dynamic-field-input--notes"
                                                              placeholder="@Model.Fields[fieldIndex].Placeholder"
                                                              aria-describedby="@fieldHelpId"></textarea>
                                                }
                                                else
                                                {
                                                    <input asp-for="Fields[fieldIndex].Valore"
                                                           class="form-control dynamic-field-input"
                                                           placeholder="@Model.Fields[fieldIndex].Placeholder"
                                                           aria-describedby="@fieldHelpId" />
                                                }
                                                break;
                                        }
                                    </div>

                                    @if (hasHelpText)
                                    {
                                        <div id="@fieldHelpId" class="dynamic-field-help">
                                            <span class="dynamic-field-help__label">Nota campo</span>
                                            <span class="dynamic-field-help__text">@Model.Fields[fieldIndex].HelpText</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </section>
        }
    }

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">@(Model.RecordId == 0 ? "Salva misura" : "Aggiorna misura")</button>
        <a asp-controller="@backController" asp-action="@backAction" asp-all-route-data="backRouteValues" class="btn btn-outline-secondary">Annulla</a>
    </div>
</form>
    </div>

    @if (!string.IsNullOrEmpty(Model.TypeImageUrl))
    {
        <div class="col-lg-6 mt-4 mt-lg-0">
            <div class="sticky-top" style="top: 100px;">
                <div class="card card-static shadow-sm border-0">
                    <div class="card-header bg-transparent border-bottom-0 pb-0 pt-4 px-4 text-center">
                        <h3 class="card-title h6 rounded bg-gold text-white d-inline-block py-2 px-4 mb-0 shadow-sm"><i class="bi bi-image me-2"></i>Modello di Riferimento</h3>
                    </div>
                    <div class="card-body p-4 text-center">
                        <a href="#" data-bs-toggle="modal" data-bs-target="#imageZoomModal">
                            <img src="@Model.TypeImageUrl" class="img-fluid rounded shadow-sm" alt="Modello di misurazione" style="max-height: 65vh; object-fit: contain; width: 100%; border: 1px solid var(--border); cursor: zoom-in;" />
                        </a>
                        <div class="form-text mt-2"><i class="bi bi-zoom-in"></i> Clicca sulla foto per ingrandirla</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(Model.TypeImageUrl))
{
<div class="modal fade" id="imageZoomModal" tabindex="-1" aria-labelledby="imageZoomModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content border-0" style="background-color: transparent;">
      <div class="modal-header border-0 pb-0 justify-content-end p-2 position-absolute w-100" style="z-index: 10;">
        <button type="button" class="btn-close btn-close-white fs-4 rounded-circle p-2" style="background-color: rgba(0,0,0,0.5);" data-bs-dismiss="modal" aria-label="Chiudi"></button>
      </div>
      <div class="modal-body text-center p-0">
        <img src="@Model.TypeImageUrl" class="img-fluid rounded shadow-lg" alt="Modello Ingrandito" style="max-height: 90vh; object-fit: contain; width: 100%;" />
      </div>
    </div>
  </div>
</div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
