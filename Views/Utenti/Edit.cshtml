@model MisureRicci.Models.ViewModels.UtenteAdminPageViewModel

@{
    ViewData["Title"] = "Modifica Utente";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Access management</span>
        <h1 class="page-title">Modifica utente</h1>
        <p class="page-subtitle">Aggiorna ruolo, contesto boutique e stato di attivazione dell'account.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Torna alla lista</a>
    </div>
</section>

<form asp-action="Edit" method="post" class="form-shell">
    <section class="form-section">
        <div asp-validation-summary="All"></div>
        <input type="hidden" asp-for="Form.Id" />

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Form.NomeCompleto" class="form-label"></label>
                <input asp-for="Form.NomeCompleto" class="form-control" />
                <span asp-validation-for="Form.NomeCompleto" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Form.UserName" class="form-label"></label>
                <input asp-for="Form.UserName" class="form-control" />
                <span asp-validation-for="Form.UserName" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Form.Email" class="form-label"></label>
                <input asp-for="Form.Email" class="form-control" />
                <span asp-validation-for="Form.Email" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Form.Ruolo" class="form-label"></label>
                <select asp-for="Form.Ruolo" class="form-select">
                    <option value="Admin">Amministratore</option>
                    <option value="Sartoria">Mastro Sarto</option>
                    <option value="Boutique">Personale Boutique</option>
                    <option value="Manager">Regional Manager</option>
                </select>
                <span asp-validation-for="Form.Ruolo" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Form.NegozioId" class="form-label"></label>
                <select asp-for="Form.NegozioId" class="form-select" asp-items="@(new SelectList(Model.Negozi, "Id", "Nome"))">
                    <option value="">-- Seleziona Negozio --</option>
                </select>
                <span asp-validation-for="Form.NegozioId" class="text-danger"></span>
            </div>
        </div>

        <div class="form-check form-switch mt-4">
            <input asp-for="Form.Attivo" class="form-check-input" />
            <label asp-for="Form.Attivo" class="form-check-label"></label>
        </div>
    </section>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Salva</button>
        <a asp-action="Delete" asp-route-id="@Model.Form.Id" class="btn btn-outline-danger ms-auto">Elimina</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
