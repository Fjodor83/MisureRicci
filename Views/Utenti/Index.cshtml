@model IEnumerable<MisureRicci.Models.Utente>

@{
    ViewData["Title"] = "Gestione Utenti Staff";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="sr-title">GESTIONE UTENTI (STAFF)</h1>
    <a asp-action="Create" class="btn btn-primary">NUOVO UTENTE STAFF</a>
</div>

<div class="card p-0 overflow-hidden">
    <table class="table table-hover mb-0">
        <thead class="bg-dark text-white">
            <tr>
                <th class="ps-4">UTENTE</th>
                <th>NOMINATIVO</th>
                <th>RUOLO</th>
                <th>NEGOZIO</th>
                <th>STATO</th>
                <th class="pe-4 text-end">AZIONI</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="ps-4">
                        <div class="d-flex align-items-center">
                            <div class="avatar-circle me-3">@item.Username.Substring(0, 1).ToUpper()</div>
                            <div>
                                <span class="text-white fw-bold">@@@item.Username</span><br />
                                <small class="text-muted">@item.Email</small>
                            </div>
                        </div>
                    </td>
                    <td>@item.NomeCompleto</td>
                    <td>
                        <span class="badge border border-gold text-gold">@item.Ruolo</span>
                    </td>
                    <td>@(item.Negozio?.Nome ?? "N/D")</td>
                    <td>
                        @if (item.Attivo)
                        {
                            <span class="text-success small"><i class="bi bi-circle-fill me-1"></i> Attivo</span>
                        }
                        else
                        {
                            <span class="text-muted small"><i class="bi bi-circle-fill me-1"></i> Inattivo</span>
                        }
                    </td>
                    <td class="pe-4 text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-gold">PROFILO</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .avatar-circle {
        width: 35px;
        height: 35px;
        background-color: #c5a059;
        color: #0c121e;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }
</style>
