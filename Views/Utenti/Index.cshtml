@model IEnumerable<MisureRicci.Models.ApplicationUser>

@{
    ViewData["Title"] = "Gestione Utenti Staff";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Access management</span>
        <h1 class="page-title">Staff e sicurezza</h1>
        <p class="page-subtitle">Gestione utenti, ruoli e assegnazioni boutique in una vista amministrativa coerente.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-badge-fill me-2"></i>Nuovo utente staff
        </a>
    </div>
</section>

<section class="data-table-card">
    <div class="table-toolbar">
        <div>
            <h2 class="detail-card__title">Utenti configurati</h2>
            <div class="toolbar-meta">Ruolo, boutique e stato dell'account.</div>
        </div>
        <span class="toolbar-chip">@Model.Count() utenti</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Utente</th>
                    <th>Nominativo</th>
                    <th>Ruolo</th>
                    <th>Boutique</th>
                    <th>Stato</th>
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="table-user">
                                <div class="avatar-circle">@(item.UserName?.Substring(0, 1).ToUpper() ?? "?")</div>
                                <div class="table-user__body">
                                    <span class="table-user__title">@@@item.UserName</span>
                                    <span class="table-user__meta">@item.Email</span>
                                </div>
                            </div>
                        </td>
                        <td class="fw-bold">@item.NomeCompleto</td>
                        <td><span class="status-pill status-pill--accent">@item.Ruolo.ToUpper()</span></td>
                        <td>@(item.Negozio?.Nome ?? "Global HQ")</td>
                        <td><span class="status-pill @(item.Attivo ? "status-pill--success" : "status-pill--neutral")">@(item.Attivo ? "Attivo" : "Inattivo")</span></td>
                        <td class="text-end">
                            <div class="page-actions justify-content-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-gold">Profilo</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Modifica</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
