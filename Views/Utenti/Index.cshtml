@model IEnumerable<MisureRicci.Models.Utente>

@{
    ViewData["Title"] = "Gestione Utenti Staff";
}

<div class="d-flex justify-content-between align-items-center mb-4 animate__animated animate__fadeInDown">
    <div>
        <h1 class="page-title">STAFF E SICUREZZA</h1>
        <p class="page-subtitle mt-2 mb-0">Gestione Utenti, Sarti e Manager SaaS</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-badge-fill me-2"></i> Nuovo Utente Staff</a>
</div>

<div class="card p-0 overflow-hidden animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">UTENTE</th>
                    <th>NOMINATIVO</th>
                    <th>RUOLO</th>
                    <th>BOUTIQUE</th>
                    <th>STATO</th>
                    <th class="pe-4 text-end">AZIONI</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="transition: all 0.3s ease;">
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="avatar-circle me-3">@item.Username.Substring(0, 1).ToUpper()</div>
                                <div>
                                    <span class="text-white fw-bold font-monospace">@@@item.Username</span><br />
                                    <small class="text-muted">@item.Email</small>
                                </div>
                            </div>
                        </td>
                        <td class="fw-bold font-cinzel letter-spacing-1">@item.NomeCompleto</td>
                        <td>
                            <span class="badge border border-gold text-gold p-2">@item.Ruolo.ToUpper()</span>
                        </td>
                        <td class="text-muted">@(item.Negozio?.Nome ?? "GLOBAL HQ")</td>
                        <td>
                            @if (item.Attivo)
                            {
                                <span class="text-success small fw-bold"><i class="bi bi-circle-fill me-1"></i> ONLINE</span>
                            }
                            else
                            {
                                <span class="text-muted small"><i class="bi bi-circle me-1"></i> OFFLINE</span>
                            }
                        </td>
                        <td class="pe-4 text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-gold" title="Profilo">PROFILO</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Modifica"><i class="bi bi-pencil-square"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .avatar-circle {
        width: 35px;
        height: 35px;
        background-color: #c5a059;
        background: linear-gradient(135deg, #c5a059, #e2c07d);
        color: #0c121e;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        box-shadow: 0 0 10px rgba(197, 160, 89, 0.4);
    }
</style>
