@model MisureRicci.Models.ViewModels.UtenteAdminPageViewModel

@{
    ViewData["Title"] = "Nuovo Utente Staff";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Access management</span>
        <h1 class="page-title">Crea account staff</h1>
        <p class="page-subtitle">Definisci identita', ruolo, boutique assegnata e credenziali iniziali.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</section>

<form asp-action="Create" method="post" class="form-shell">
    <div asp-validation-summary="All"></div>

    <section class="form-section">
        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Form.UserName" class="form-label">Username</label>
                <input asp-for="Form.UserName" class="form-control" placeholder="es: m.rossi" />
                <span asp-validation-for="Form.UserName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Form.NomeCompleto" class="form-label">Nome completo</label>
                <input asp-for="Form.NomeCompleto" class="form-control" />
                <span asp-validation-for="Form.NomeCompleto" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Form.Email" class="form-label">Email</label>
                <input asp-for="Form.Email" class="form-control" />
                <span asp-validation-for="Form.Email" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Form.Ruolo" class="form-label">Ruolo</label>
                <select asp-for="Form.Ruolo" class="form-select">
                    @if (User.IsInRole("Admin"))
                    {
                        <option value="Admin">Amministratore</option>
                    }
                    <option value="Sartoria" selected>Mastro Sarto</option>
                    <option value="Boutique">Personale Boutique</option>
                    <option value="Manager">Regional Manager</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="Form.NegozioId" class="form-label">Negozio assegnato</label>
                @if (User.IsInRole("Admin"))
                {
                    <select asp-for="Form.NegozioId" class="form-select" asp-items="@(new SelectList(Model.Negozi, "Id", "Nome"))">
                        <option value="">Seleziona negozio...</option>
                    </select>
                }
                else
                {
                    <input type="hidden" asp-for="Form.NegozioId" />
                    <input class="form-control" value="@(Model.Negozi.FirstOrDefault(n => n.Id == Model.Form.NegozioId)?.Nome ?? "Tuo negozio")" readonly />
                }
                <span asp-validation-for="Form.NegozioId" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Form.Password" class="form-label">Password</label>
                <input asp-for="Form.Password" class="form-control" />
                <span asp-validation-for="Form.Password" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Form.ConfirmPassword" class="form-label">Conferma Password</label>
                <input asp-for="Form.ConfirmPassword" class="form-control" />
                <span asp-validation-for="Form.ConfirmPassword" class="text-danger"></span>
            </div>
        </div>
    </section>

    <div class="form-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
        <button type="submit" class="btn btn-primary">Crea account staff</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
