@model MisureRicci.Models.Utente
@{ ViewData["Title"] = "Profilo Staff"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="sr-title">PROFILO STAFF</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-gold me-2">MODIFICA</a>
        <a asp-action="Index" class="btn btn-outline-secondary">INDIETRO</a>
    </div>
</div>

<div class="card p-4">
    <div class="row">
        <div class="col-md-6">
            <p class="sr-gold small">USERNAME</p>
            <p class="fw-bold">@@@Model.Username</p>
            <p class="sr-gold small">NOME COMPLETO</p>
            <p class="fw-bold">@Model.NomeCompleto</p>
            <p class="sr-gold small">EMAIL</p>
            <p class="fw-bold">@Model.Email</p>
        </div>
        <div class="col-md-6">
            <p class="sr-gold small">RUOLO</p>
            <p><span class="badge border border-gold text-gold p-2">@Model.Ruolo.ToUpper()</span></p>
            <p class="sr-gold small">NEGOZIO</p>
            <p class="fw-bold">@(Model.Negozio?.Nome ?? "Global HQ")</p>
            <p class="sr-gold small">STATO</p>
            <p>@(Model.Attivo ? "🟢 Attivo" : "⚪ Inattivo")</p>
        </div>
    </div>
</div>
