@model MisureRicci.Models.ViewModels.DashboardKpiViewModel
@{
    ViewData["Title"] = "Business Dashboard";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Business control</span>
        <h1 class="page-title">Dashboard operativa dell’atelier</h1>
        <p class="page-subtitle">
            Vista centrale per clienti, boutique, misure e flussi operativi. Il layout mette in primo piano
            le aree di lavoro piu' usate e riduce il rumore visivo nei passaggi quotidiani.
        </p>
        <div class="page-actions">
            <a asp-controller="Clienti" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-people-fill me-2"></i>Apri anagrafica clienti
            </a>
            <a asp-controller="Commissioni" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-journal-check me-2"></i>Vai alle commissioni
            </a>
        </div>
    </div>
    <div class="page-hero__aside">
        <div class="page-surface">
            <div class="detail-row">
                <span class="detail-row__label">Stato workspace</span>
                <span class="detail-row__value">Online e sincronizzato</span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Aggiornato</span>
                <span class="detail-row__value">@DateTime.Now.ToString("dd MMM yyyy")</span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Focus</span>
                <span class="detail-row__value">Operazioni, report e archivio misure</span>
            </div>
        </div>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <div class="metric-card__head">
            <div>
                <div class="metric-label">Totale clienti</div>
                <div class="metric-value">@Model.TotalClients</div>
            </div>
            <div class="metric-card__icon"><i class="bi bi-people-fill"></i></div>
        </div>
        <div class="metric-meta">Base clienti attiva e consultabile da archivio centrale.</div>
        <div class="metric-bar metric-bar--78"><span></span></div>
    </article>
    <article class="metric-card">
        <div class="metric-card__head">
            <div>
                <div class="metric-label">Boutique attive</div>
                <div class="metric-value">@Model.TotalStores</div>
            </div>
            <div class="metric-card__icon"><i class="bi bi-shop"></i></div>
        </div>
        <div class="metric-meta">Presidio territoriale gestito da una singola shell operativa.</div>
        <div class="metric-bar metric-bar--64"><span></span></div>
    </article>
    <article class="metric-card">
        <div class="metric-card__head">
            <div>
                <div class="metric-label">Misure archiviate</div>
                <div class="metric-value">@Model.TotalMeasurements</div>
            </div>
            <div class="metric-card__icon"><i class="bi bi-rulers"></i></div>
        </div>
        <div class="metric-meta">Registro storico disponibile per tipologia, cliente e commessa.</div>
        <div class="metric-bar metric-bar--72"><span></span></div>
    </article>
    <article class="metric-card">
        <div class="metric-card__head">
            <div>
                <div class="metric-label">Staff operativo</div>
                <div class="metric-value">@Model.TotalStaff</div>
            </div>
            <div class="metric-card__icon"><i class="bi bi-person-badge-fill"></i></div>
        </div>
        <div class="metric-meta">Utenti, ruoli e responsabilita' concentrati in un unico pannello.</div>
        <div class="metric-bar metric-bar--58"><span></span></div>
    </article>
</section>

<section class="page-grid page-grid--sidebar">
    <div class="feature-grid">
        <article class="feature-card">
            <div class="feature-card__icon"><i class="bi bi-person-lines-fill"></i></div>
            <div>
                <h2 class="feature-card__title">Clienti e dossier</h2>
                <p class="feature-card__text">Anagrafica, preferenze e storico misure raccolti in una vista chiara e leggibile.</p>
            </div>
            <div class="feature-card__actions">
                <a asp-controller="Clienti" asp-action="Index" class="btn btn-outline-gold">Apri clienti</a>
            </div>
        </article>

        <article class="feature-card">
            <div class="feature-card__icon"><i class="bi bi-journal-text"></i></div>
            <div>
                <h2 class="feature-card__title">Commissioni</h2>
                <p class="feature-card__text">Ordini, stati, note operative e timeline evento nella stessa esperienza.</p>
            </div>
            <div class="feature-card__actions">
                <a asp-controller="Commissioni" asp-action="Index" class="btn btn-outline-gold">Apri commissioni</a>
            </div>
        </article>

        <article class="feature-card">
            <div class="feature-card__icon"><i class="bi bi-sliders2"></i></div>
            <div>
                <h2 class="feature-card__title">Tipologie dinamiche</h2>
                <p class="feature-card__text">Configurazione campi e template pensata per amministrazione e manutenzione rapida.</p>
            </div>
            <div class="feature-card__actions">
                <a asp-controller="AdminMeasurementTypes" asp-action="Index" class="btn btn-outline-secondary">Configura tipologie</a>
            </div>
        </article>

        <article class="feature-card">
            <div class="feature-card__icon"><i class="bi bi-file-earmark-arrow-down"></i></div>
            <div>
                <h2 class="feature-card__title">Export e report</h2>
                <p class="feature-card__text">CSV coerenti con il tenant e accessibili senza uscire dal flusso di lavoro.</p>
            </div>
            <div class="feature-card__actions">
                <a asp-controller="Report" asp-action="Index" class="btn btn-primary">Apri report</a>
            </div>
        </article>
    </div>

    <div class="detail-stack">
        <article class="detail-card">
            <div class="detail-card__header">
                <div>
                    <h2 class="detail-card__title">Registro rapido</h2>
                    <p class="detail-card__subtitle">Accesso diretto alle categorie di misura piu' usate.</p>
                </div>
            </div>
            <div class="quick-links">
                <a asp-controller="Measurements" asp-action="GlobalRegistry" asp-route-filter="giacca" class="quick-link">
                    <span><i class="bi bi-suit-spade-fill me-2 text-gold"></i>Giacche e capispalla</span>
                    <i class="bi bi-arrow-right"></i>
                </a>
                <a asp-controller="Measurements" asp-action="GlobalRegistry" asp-route-filter="pantalone" class="quick-link">
                    <span><i class="bi bi-layout-sidebar-inset me-2 text-gold"></i>Pantaloni</span>
                    <i class="bi bi-arrow-right"></i>
                </a>
                <a asp-controller="Measurements" asp-action="GlobalRegistry" asp-route-filter="camicia" class="quick-link">
                    <span><i class="bi bi-layers-fill me-2 text-gold"></i>Camicie</span>
                    <i class="bi bi-arrow-right"></i>
                </a>
                <a asp-controller="Measurements" asp-action="GlobalRegistry" asp-route-filter="scarpe" class="quick-link">
                    <span><i class="bi bi-circle-square me-2 text-gold"></i>Scarpe e accessori</span>
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </article>

        <article class="detail-card">
            <div class="detail-card__header">
                <div>
                    <h2 class="detail-card__title">Direzione visiva</h2>
                    <p class="detail-card__subtitle">Interfaccia ripensata per leggibilita', densita' informativa e decisioni rapide.</p>
                </div>
            </div>
            <div class="detail-list">
                <div class="detail-row">
                    <span class="detail-row__label">Gerarchia</span>
                    <span class="detail-row__value">Hero chiari, tabelle pulite, form divisi per sezioni operative.</span>
                </div>
                <div class="detail-row">
                    <span class="detail-row__label">Palette</span>
                    <span class="detail-row__value">Neutri caldi, bronzo sartoriale e contrasti piu' controllati.</span>
                </div>
                <div class="detail-row">
                    <span class="detail-row__label">Mobile first</span>
                    <span class="detail-row__value">Sidebar collassabile, CTA leggibili e blocchi responsivi.</span>
                </div>
            </div>
        </article>
    </div>
</section>
