@{
    ViewData["Title"] = "Standard Sartoriali";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Qualità di confezione</span>
        <h1 class="page-title">Standard Sartoriali</h1>
        <p class="page-subtitle">Criteri condivisi per rilievo misure, compilazione commesse e controllo qualità del capo.</p>
    </div>
</section>

<section class="page-surface">
    <div class="row g-4">
        <div class="col-md-6">
            <h2 class="detail-card__title">Rilievo misure</h2>
            <p class="text-muted mb-0">Effettua la misurazione in postura naturale, annota eventuali asimmetrie e registra note contestuali utili alla confezione.</p>
        </div>
        <div class="col-md-6">
            <h2 class="detail-card__title">Validazione dati</h2>
            <p class="text-muted mb-0">Confronta i valori con lo storico cliente per intercettare variazioni anomale prima di confermare una nuova scheda misure.</p>
        </div>
        <div class="col-md-6">
            <h2 class="detail-card__title">Commissione sartoriale</h2>
            <p class="text-muted mb-0">Prima del passaggio in lavorazione, assicurati che tessuto, modello e misure collegate siano coerenti con il capo richiesto.</p>
        </div>
        <div class="col-md-6">
            <h2 class="detail-card__title">Controllo finale</h2>
            <p class="text-muted mb-0">Usa la scheda ordine come checklist finale per verificare vestibilità, finiture e completezza degli allegati PDF.</p>
        </div>
    </div>
</section>