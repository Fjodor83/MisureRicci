@{
    ViewData["Title"] = "Report & Export";
    var isAdmin = User.IsInRole("Admin");
    var isManager = User.IsInRole("Manager");
    var isBoutique = User.IsInRole("Boutique");
    var canSeeAll = isAdmin;
}
<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Reporting workspace</span>
        <h1 class="page-title">Report operativi</h1>
        <p class="page-subtitle">Export sicuri e coerenti con il perimetro di accesso dell'utente autenticato.</p>
    </div>
    <div class="page-actions">
        <span class="status-pill @(isAdmin ? "status-pill--accent" : "status-pill--success")">
            @(isAdmin ? "Accesso globale" : "Accesso scoped")
        </span>
    </div>
</section>

<section class="feature-grid">
    <article class="feature-card">
        <div class="feature-card__icon"><i class="bi bi-people-fill"></i></div>
        <div>
            <h2 class="feature-card__title">Anagrafica clienti</h2>
            <p class="feature-card__text">Esporta codice cliente, contatti, paese e data registrazione in CSV compatibile con Excel.</p>
        </div>
        <div class="feature-card__actions">
            <a asp-controller="Report" asp-action="ExportClientiCsv" class="btn btn-outline-gold">Scarica export clienti</a>
            <a asp-controller="Clienti" asp-action="Index" class="btn btn-outline-secondary">Apri archivio clienti</a>
        </div>
    </article>

    <article class="feature-card">
        <div class="feature-card__icon"><i class="bi bi-rulers"></i></div>
        <div>
            <h2 class="feature-card__title">Storico misure</h2>
            <p class="feature-card__text">Esporta cronologia misure, tipo record e note operative con visibilita' coerente al tenant corrente.</p>
        </div>
        <div class="feature-card__actions">
            <a asp-controller="Report" asp-action="ExportMisureCsv" class="btn btn-outline-gold">Scarica export misure</a>
            <a asp-controller="Measurements" asp-action="GlobalRegistry" class="btn btn-outline-secondary">Apri registro misure</a>
        </div>
    </article>
</section>

<section class="page-surface mt-4">
    <div class="detail-list">
        <div class="detail-row">
            <span class="detail-row__label">Sicurezza</span>
            <span class="detail-row__value">I CSV sono sanitizzati contro formula injection.</span>
        </div>
        <div class="detail-row">
            <span class="detail-row__label">Tenant scope</span>
            <span class="detail-row__value">
                @(isAdmin
                    ? "Gli export includono tutte le boutique abilitate."
                    : "Gli export includono solo i dati del negozio assegnato.")
            </span>
        </div>
        <div class="detail-row">
            <span class="detail-row__label">Percorso rapido</span>
            <span class="detail-row__value">
                <a asp-controller="Commissioni" asp-action="Index" class="btn btn-sm btn-primary">Apri commissioni</a>
            </span>
        </div>
    </div>
</section>
