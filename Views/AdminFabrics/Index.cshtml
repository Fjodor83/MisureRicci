@model IEnumerable<MisureRicci.Models.Fabric>

@{
    ViewData["Title"] = "Catalogo Tessuti";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Admin configuration</span>
        <h1 class="page-title">Catalogo Tessuti</h1>
        <p class="page-subtitle">Gestisci i tessuti disponibili nel sistema.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Nuovo tessuto
        </a>
    </div>
</section>

<section class="data-table-card">
    <div class="table-toolbar">
        <div>
            <h2 class="detail-card__title">Tessuti disponibili</h2>
            <div class="toolbar-meta">Elenco dei tessuti disponibili nel catalogo.</div>
        </div>
        <span class="toolbar-chip">@Model.Count() tessuti</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Composizione</th>
                    <th>Descrizione</th>
                    <th>Stato</th>
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Nessun tessuto configurato</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Nome</td>
                            <td class="text-muted">@item.Composizione</td>
                            <td class="text-muted text-truncate" style="max-width: 300px;">@item.Descrizione</td>
                            <td><span class="status-pill @(item.IsActive ? "status-pill--success" : "status-pill--neutral")">@(item.IsActive ? "Attivo" : "Disattivo")</span></td>
                            <td class="text-end">
                                <div class="page-actions justify-content-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Modifica</a>
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" data-confirm="Eliminare questo tessuto?">Elimina</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
