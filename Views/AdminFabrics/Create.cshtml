@model MisureRicci.Models.Fabric

@{
    ViewData["Title"] = "Nuovo Tessuto";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Admin configuration</span>
        <h1 class="page-title">Nuovo tessuto</h1>
        <p class="page-subtitle">Definisci nome, composizione e altre informazioni sul tessuto.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</section>

<form asp-action="Create" method="post" class="form-shell">
    <section class="form-section">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label asp-for="Nome" class="form-label">Nome</label>
            <input asp-for="Nome" class="form-control" placeholder="Es. Lana Super 150's" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Composizione" class="form-label">Composizione</label>
            <input asp-for="Composizione" class="form-control" placeholder="Es. 100% Lana vergine" />
            <span asp-validation-for="Composizione" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Descrizione" class="form-label">Descrizione</label>
            <textarea asp-for="Descrizione" class="form-control" rows="4" placeholder="Note aggiuntive sul tessuto..."></textarea>
            <span asp-validation-for="Descrizione" class="text-danger"></span>
        </div>

        <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Attivo</label>
        </div>
    </section>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Salva tessuto</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
