@model MisureRicci.Models.ViewModels.ClientePageViewModel

@{
    ViewData["Title"] = "Modifica Cliente";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Customer maintenance</span>
        <h1 class="page-title">Aggiorna profilo cliente</h1>
        <p class="page-subtitle">Modifica dati anagrafici, assegnazione boutique e note senza alterare lo storico.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Details" asp-route-id="@Model.Cliente.Id" class="btn btn-outline-secondary">Torna al dossier</a>
    </div>
</section>

<form asp-action="Edit" asp-route-id="@Model.Cliente.Id" class="form-shell">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <input asp-for="Cliente.Id" type="hidden" />
    <input asp-for="Cliente.ClientCode" type="hidden" />
    <input asp-for="Cliente.DataRegistrazione" type="hidden" />

    <section class="form-section">
        <div class="detail-grid">
            <div class="detail-row">
                <span class="detail-row__label">Codice cliente</span>
                <span class="detail-row__value">@Model.Cliente.ClientCode</span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Data registrazione</span>
                <span class="detail-row__value">@Model.Cliente.DataRegistrazione.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <div class="form-section__header">
            <div>
                <h2 class="form-section__title">Dati personali</h2>
                <p class="form-section__text">Aggiorna anagrafica, recapiti e contesto commerciale.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Cliente.Nome" class="form-label"></label>
                <input asp-for="Cliente.Nome" class="form-control" />
                <span asp-validation-for="Cliente.Nome" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Cliente.Cognome" class="form-label"></label>
                <input asp-for="Cliente.Cognome" class="form-control" />
                <span asp-validation-for="Cliente.Cognome" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Cliente.Email" class="form-label"></label>
                <input asp-for="Cliente.Email" class="form-control" />
                <span asp-validation-for="Cliente.Email" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Cliente.Telefono" class="form-label"></label>
                <input asp-for="Cliente.Telefono" class="form-control" />
                <span asp-validation-for="Cliente.Telefono" class="text-danger"></span>
            </div>
            @if (Model.IsAdmin)
            {
                <div class="col-md-6">
                    <label asp-for="Cliente.NegozioId" class="form-label"></label>
                    <select asp-for="Cliente.NegozioId"
                            class="form-select"
                            asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Negozi, "Id", "Nome"))">
                        <option value="">Seleziona boutique</option>
                    </select>
                    <span asp-validation-for="Cliente.NegozioId" class="text-danger"></span>
                </div>
            }
        </div>
    </section>

    <section class="form-section">
        <div class="form-section__header">
            <div>
                <h2 class="form-section__title">Indirizzo</h2>
                <p class="form-section__text">Mantieni coerente il profilo logistico e territoriale del cliente.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-12">
                <label asp-for="Cliente.Indirizzo" class="form-label"></label>
                <input asp-for="Cliente.Indirizzo" class="form-control" />
                <span asp-validation-for="Cliente.Indirizzo" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Cliente.Citta" class="form-label"></label>
                <input asp-for="Cliente.Citta" class="form-control" />
                <span asp-validation-for="Cliente.Citta" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Cliente.StatoProvincia" class="form-label"></label>
                <input asp-for="Cliente.StatoProvincia" class="form-control" />
                <span asp-validation-for="Cliente.StatoProvincia" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Cliente.CodicePostale" class="form-label"></label>
                <input asp-for="Cliente.CodicePostale" class="form-control" />
                <span asp-validation-for="Cliente.CodicePostale" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Cliente.Paese" class="form-label"></label>
                <input asp-for="Cliente.Paese" class="form-control" />
                <span asp-validation-for="Cliente.Paese" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <div class="form-section__header">
            <div>
                <h2 class="form-section__title">Note operative</h2>
                <p class="form-section__text">Preferenze di calzata, dettagli sartoriali e osservazioni interne.</p>
            </div>
        </div>
        <div>
            <label asp-for="Cliente.Note" class="form-label"></label>
            <textarea asp-for="Cliente.Note" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Cliente.Note" class="text-danger"></span>
        </div>
    </section>

    <div class="form-actions">
        <a asp-action="Details" asp-route-id="@Model.Cliente.Id" class="btn btn-outline-secondary">Annulla</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save me-2"></i>Salva modifiche
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
