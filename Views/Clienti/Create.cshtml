@model MisureRicci.Models.ViewModels.ClientePageViewModel

@{
    ViewData["Title"] = "Nuovo Cliente";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Customer onboarding</span>
        <h1 class="page-title">Registra nuovo cliente</h1>
        <p class="page-subtitle">Inserisci anagrafica, contatti e dati di contesto senza uscire dal workflow principale.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</section>

<form asp-action="Create" class="form-shell">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <section class="form-section">
        <div class="form-section__header">
            <div>
                <h2 class="form-section__title">Dati personali</h2>
                <p class="form-section__text">Identita', contatto principale e boutique di riferimento.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Cliente.Nome" class="form-label">Nome</label>
                <input asp-for="Cliente.Nome" class="form-control" />
                <span asp-validation-for="Cliente.Nome" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Cliente.Cognome" class="form-label">Cognome</label>
                <input asp-for="Cliente.Cognome" class="form-control" />
                <span asp-validation-for="Cliente.Cognome" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Cliente.Email" class="form-label">Email</label>
                <input asp-for="Cliente.Email" class="form-control" />
                <span asp-validation-for="Cliente.Email" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Cliente.Telefono" class="form-label">Telefono</label>
                <input asp-for="Cliente.Telefono" class="form-control" />
                <span asp-validation-for="Cliente.Telefono" class="text-danger"></span>
            </div>
            @if (Model.IsAdmin)
            {
                <div class="col-md-6">
                    <label asp-for="Cliente.NegozioId" class="form-label">Boutique</label>
                    <select asp-for="Cliente.NegozioId"
                            class="form-select"
                            asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Negozi, "Id", "Nome"))">
                        <option value="">Seleziona boutique</option>
                    </select>
                    <span asp-validation-for="Cliente.NegozioId" class="text-danger"></span>
                </div>
            }
        </div>
    </section>

    <section class="form-section">
        <div class="form-section__header">
            <div>
                <h2 class="form-section__title">Indirizzo</h2>
                <p class="form-section__text">Dati logistici e territoriali per boutique, consegne e storico cliente.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-12">
                <label asp-for="Cliente.Indirizzo" class="form-label">Indirizzo</label>
                <input asp-for="Cliente.Indirizzo" class="form-control" />
                <span asp-validation-for="Cliente.Indirizzo" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Cliente.Citta" class="form-label">Città</label>
                <input asp-for="Cliente.Citta" class="form-control" />
                <span asp-validation-for="Cliente.Citta" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Cliente.StatoProvincia" class="form-label">Stato/Provincia</label>
                <input asp-for="Cliente.StatoProvincia" class="form-control" />
                <span asp-validation-for="Cliente.StatoProvincia" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Cliente.CodicePostale" class="form-label">Codice Postale</label>
                <input asp-for="Cliente.CodicePostale" class="form-control" />
                <span asp-validation-for="Cliente.CodicePostale" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Cliente.Paese" class="form-label">Paese</label>
                <input asp-for="Cliente.Paese" class="form-control" />
                <span asp-validation-for="Cliente.Paese" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <div class="form-section__header">
            <div>
                <h2 class="form-section__title">Note operative</h2>
                <p class="form-section__text">Preferenze, vestibilita' o annotazioni utili al lavoro sartoriale.</p>
            </div>
        </div>
        <div>
            <label asp-for="Cliente.Note" class="form-label">Note</label>
            <textarea asp-for="Cliente.Note" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Cliente.Note" class="text-danger"></span>
        </div>
    </section>

    <div class="form-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle me-2"></i>Registra cliente
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
