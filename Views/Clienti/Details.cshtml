@model MisureRicci.Models.ViewModels.ClienteDetailsViewModel

@{
    ViewData["Title"] = "Dettagli Cliente";
    var cliente = Model.Cliente;
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Customer dossier</span>
        <h1 class="page-title">@cliente.Nome @cliente.Cognome</h1>
        <p class="page-subtitle">
            Profilo cliente, recapiti, note sartoriali e cronologia misure in una singola vista di lavoro.
        </p>
    </div>
    <div class="page-actions">
        <a asp-action="Edit" asp-route-id="@cliente.Id" class="btn btn-primary">
            <i class="bi bi-pencil-square me-2"></i>Modifica
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">Torna all'elenco</a>
    </div>
</section>

@if (TempData["MeasurementError"] is string measurementError && !string.IsNullOrWhiteSpace(measurementError))
{
    <div class="alert alert-warning mb-4">@measurementError</div>
}

<div class="row g-4">
    <div class="col-xl-4">
        <article class="detail-card h-100">
            <div class="detail-hero mb-4">
                <div class="detail-hero__avatar"><i class="bi bi-person-bounding-box"></i></div>
                <div>
                    <h2 class="detail-hero__title">@cliente.ClientCode</h2>
                    <div class="detail-hero__meta">Cliente registrato il @cliente.DataRegistrazione.ToString("dd MMM yyyy")</div>
                </div>
            </div>

            <div class="detail-list mb-4">
                <div class="detail-row">
                    <span class="detail-row__label">Email</span>
                    <span class="detail-row__value">@cliente.Email</span>
                </div>
                <div class="detail-row">
                    <span class="detail-row__label">Telefono</span>
                    <span class="detail-row__value">@(string.IsNullOrWhiteSpace(cliente.Telefono) ? "Non indicato" : cliente.Telefono)</span>
                </div>
                <div class="detail-row">
                    <span class="detail-row__label">Stato profilo</span>
                    <span class="detail-row__value">Attivo e disponibile per misure e commissioni</span>
                </div>
            </div>

            <div class="d-grid gap-2">
                <a asp-controller="Measurements" asp-action="Index" asp-route-clienteId="@cliente.Id" class="btn btn-outline-gold">
                    <i class="bi bi-rulers me-2"></i>Nuova misura
                </a>
                <a asp-controller="Commissioni" asp-action="Create" asp-route-clienteId="@cliente.Id" class="btn btn-outline-gold">
                    <i class="bi bi-journal-plus me-2"></i>Nuova commissione
                </a>
                <a asp-controller="Commissioni" asp-action="Index" asp-route-clienteId="@cliente.Id" class="btn btn-outline-secondary">
                    <i class="bi bi-list-check me-2"></i>Vedi commissioni
                </a>
                <a href="/pdf/dossier/@cliente.Id" target="_blank" class="btn btn-outline-secondary">
                    <i class="bi bi-printer me-2"></i>Stampa dossier
                </a>
            </div>
        </article>
    </div>

    <div class="col-xl-8">
        <div class="detail-stack">
            <article class="detail-card">
                <div class="detail-card__header">
                    <div>
                        <h2 class="detail-card__title">Profilo e preferenze</h2>
                        <p class="detail-card__subtitle">Contatti, indirizzo e note sartoriali del cliente.</p>
                    </div>
                </div>
                <div class="detail-grid">
                    <div class="detail-list">
                        <div class="detail-row">
                            <span class="detail-row__label">Indirizzo</span>
                            <span class="detail-row__value">@cliente.Indirizzo</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-row__label">Citta' / CAP</span>
                            <span class="detail-row__value">@cliente.Citta - @cliente.CodicePostale</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-row__label">Provincia / Paese</span>
                            <span class="detail-row__value">@cliente.StatoProvincia - @cliente.Paese</span>
                        </div>
                    </div>
                    <div class="detail-list">
                        <div class="detail-row">
                            <span class="detail-row__label">Note sartoriali</span>
                            <span class="detail-row__value">
                                @(string.IsNullOrWhiteSpace(cliente.Note)
                                    ? "Nessuna preferenza o nota operativa registrata."
                                    : cliente.Note)
                            </span>
                        </div>
                    </div>
                </div>
            </article>

            <article class="data-table-card">
                <div class="table-toolbar">
                    <div>
                        <h2 class="detail-card__title">Storico misure</h2>
                        <div class="toolbar-meta">Cronologia completa delle schede associate al cliente.</div>
                    </div>
                    <span class="toolbar-chip">@((Model.History?.Count ?? 0)) record</span>
                </div>

                @if (Model.History != null && Model.History.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Categoria</th>
                                    <th class="text-end">Azione</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in (List<MisureRicci.Models.MisureCliente>)Model.History)
                                {
                                    <tr>
                                        <td>@entry.DataCreazione.ToString("dd MMM yyyy - HH:mm")</td>
                                        <td><span class="table-code">@entry.TipoMisura.ToUpper()</span></td>
                                        <td class="text-end">
                                            <a asp-controller="Measurements"
                                               asp-action="Details"
                                               asp-route-id="@entry.RecordId"
                                               asp-route-tipoMisura="@entry.TipoMisura"
                                               asp-route-registryId="@entry.Id"
                                               class="btn btn-sm btn-outline-gold">Apri scheda</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-state__icon"><i class="bi bi-file-earmark-plus"></i></div>
                        <h3 class="empty-state__title">Nessuna misura registrata</h3>
                        <p class="empty-state__text">Il dossier e' pronto, ma non esistono ancora misure collegate a questo cliente.</p>
                        <a asp-controller="Measurements" asp-action="Index" asp-route-clienteId="@cliente.Id" class="btn btn-primary">Crea prima misura</a>
                    </div>
                }
            </article>
        </div>
    </div>
</div>
