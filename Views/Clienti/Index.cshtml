@model IEnumerable<MisureRicci.Models.Cliente>

@{
    ViewData["Title"] = "Gestione Clienti";
}

<div class="d-flex justify-content-between align-items-center mb-4 animate__animated animate__fadeInDown">
    <div>
        <h1 class="page-title">ANAGRAFICA CLIENTI</h1>
        <p class="page-subtitle mt-2 mb-0">Database Sartoriale Globale</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus-fill me-2"></i> Nuovo Cliente</a>
</div>

<div class="card p-4 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
    <form asp-action="Index" method="get" class="row g-3">
        <div class="col-md-10">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-gold text-gold"><i class="bi bi-search" style="color: var(--sr-gold);"></i></span>
                <input type="text" name="searchString" class="form-control border-start-0 ps-0" style="box-shadow: none;" placeholder="Cerca per nome, cognome o codice sartoriale..." value="@ViewData["CurrentFilter"]" />
            </div>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-gold w-100 h-100">CERCA</button>
        </div>
    </form>
</div>

<div class="card overflow-hidden animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Codice</th>
                    <th>Nome Completo</th>
                    <th>Località</th>
                    <th>Email / Contatto</th>
                    <th>Primo Incontro</th>
                    <th class="text-end">Registro Misure</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr style="transition: all 0.3s ease;">
                    <td><span class="badge" style="background: rgba(212, 175, 55, 0.1); color: var(--sr-gold); border: 1px solid rgba(212, 175, 55, 0.3); letter-spacing: 1px;">@item.ClientCode</span></td>
                    <td class="fw-bold font-cinzel" style="letter-spacing: 1px;">@item.Nome @item.Cognome</td>
                    <td class="text-muted"><i class="bi bi-geo-alt-fill me-1 small"></i> @item.Paese</td>
                    <td class="text-muted small" style="font-family: monospace;">@item.Email</td>
                    <td class="small text-muted">@item.DataRegistrazione.ToString("dd MMMM yyyy")</td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-gold" title="Storico Misure"><i class="bi bi-folder2-open me-2"></i> DOSSIER</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Modifica"><i class="bi bi-pencil-square"></i></a>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex justify-content-center mt-4">
    <nav aria-label="Page navigation">
        <ul class="pagination pagination-sm">
            @for (int i = 1; i <= (ViewBag.TotalPages ?? 1); i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchString="@ViewBag.SearchString">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>

