@model MisureRicci.Models.ViewModels.ClientiIndexViewModel

@{
    ViewData[index: "Title"] = "Gestione Clienti";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Customer archive</span>
        <h1 class="page-title">Clienti e Dossier Misure</h1>
        <p class="page-subtitle">
            Archivio clienti, ricerca rapida e accesso diretto ai dossier sartoriali senza cambiare flusso.
        </p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus-fill me-2"></i>Nuovo cliente
        </a>
        <a asp-controller="Measurements" asp-action="GlobalRegistry" class="btn btn-outline-secondary">
            <i class="bi bi-rulers me-2"></i>Registro Misure
        </a>
    </div>
</section>

<section class="page-surface mb-4">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <div class="col-lg-9">
            Ricerca Clienti
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text"
                       name="searchString"
                       class="form-control"
                       placeholder="Cerca per nome, cognome o codice cliente..."
                       value="@Model.SearchString" />
            </div>
        </div>
        <div class="col-lg-3 d-grid">
            <button type="submit" class="btn btn-outline-gold">
                <i class="bi bi-funnel me-2"></i>Applica filtro
            </button>
        </div>
    </form>
</section>

<section class="data-table-card">
    <div class="table-toolbar">
        <div>
            <h2 class="detail-card__title">Elenco clienti</h2>
            <div class="toolbar-meta">
                @(string.IsNullOrWhiteSpace(Model.SearchString)
                    ? "Vista completa dell'anagrafica clienti."
                    : $"Filtro attivo: {Model.SearchString}")
            </div>
        </div>
        <span class="toolbar-chip">@Model.Clienti.Count() clienti visibili</span>
    </div>

    @if (Model.Clienti.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Codice</th>
                        <th>Cliente</th>
                        <th>Localita'</th>
                        <th>Contatto</th>
                        <th>Registrato il</th>
                        <th class="text-end">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Clienti)
                    {
                        <tr>
                            <td><span class="table-code">@item.ClientCode</span></td>
                            <td>
                                <div class="table-user">
                                    <div class="table-user__body">
                                        <span class="table-user__title">@item.Nome @item.Cognome</span>
                                    </div>
                                </div>
                            </td>
                            <td>@item.Citta, @item.Paese</td>
                            <td class="text-muted">@item.Email</td>
                            <td>@item.DataRegistrazione.ToString("dd MMM yyyy")</td>
                            <td class="text-end">
                                <div class="page-actions justify-content-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-gold">Dossier</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Modifica</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3 me-2"></i>Elimina</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state__icon"><i class="bi bi-search"></i></div>
            <h3 class="empty-state__title">Nessun cliente trovato</h3>
            <p class="empty-state__text">
                Prova a rimuovere il filtro oppure registra un nuovo cliente per iniziare il flusso misure.
            </p>
            <a asp-action="Create" class="btn btn-primary">Registra cliente</a>
        </div>
    }
</section>

@if (Model.TotalPages > 1)
{
    <div class="d-flex justify-content-center mt-4">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">

                        @{
                            var i1 = i;
                        }
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i1"
                           asp-route-searchString="@Model.SearchString">@i1</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}
