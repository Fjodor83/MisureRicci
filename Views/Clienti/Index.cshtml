@model IEnumerable<MisureRicci.Models.Cliente>

@{
    ViewData["Title"] = "Gestione Clienti";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="sr-title mb-0">GESTIONALE CLIENTI</h1>
    <a asp-action="Create" class="btn btn-primary">NUOVO CLIENTE</a>
</div>

<div class="card p-4 mb-4">
    <form asp-action="Index" method="get" class="row g-3">
        <div class="col-md-10">
            <input type="text" name="searchString" class="form-control" placeholder="Cerca per nome, cognome o codice..." value="@ViewData["CurrentFilter"]" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-gold w-100">CERCA</button>
        </div>
    </form>
</div>

<div class="card overflow-hidden">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr class="sr-gold text-uppercase small letter-spacing-1">
                    <th>Codice</th>
                    <th>Nome Completo</th>
                    <th>Paese</th>
                    <th>Email</th>
                    <th>Data Reg.</th>
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td><span class="badge bg-navy border-gold sr-gold">@item.ClientCode</span></td>
                    <td class="fw-bold">@item.Nome @item.Cognome</td>
                    <td>@item.Paese</td>
                    <td class="text-muted">@item.Email</td>
                    <td class="small">@item.DataRegistrazione.ToString("dd/MM/yyyy")</td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-gold">DETTAGLI</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">MODIFICA</a>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .btn-outline-gold {
        color: var(--sr-gold);
        border-color: var(--sr-gold);
    }
    .btn-outline-gold:hover {
        background-color: var(--sr-gold);
        color: var(--sr-dark);
    }
    .letter-spacing-1 { letter-spacing: 1px; }
    .bg-navy { background-color: var(--sr-navy); }
    .border-gold { border: 1px solid var(--sr-gold); }
</style>
