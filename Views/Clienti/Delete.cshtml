@model MisureRicci.Models.Cliente

@{
    ViewData["Title"] = "Elimina Cliente";
}

<div class="confirm-shell">
    <section class="confirm-card">
        <div class="confirm-card__icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <h1 class="confirm-card__title">Elimina cliente</h1>
        <p class="confirm-card__text">
            Stai per rimuovere il profilo di <strong>@Model.Nome @Model.Cognome</strong>.
            L'operazione puo' coinvolgere anche lo storico misure in base alla configurazione del database
            e non e' reversibile.
        </p>

        <form asp-action="Delete" method="post" class="form-actions justify-content-center mt-4">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash3 me-2"></i>Conferma eliminazione
            </button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Annulla</a>
        </form>
    </section>
</div>
