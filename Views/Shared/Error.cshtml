@model ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="confirm-shell">
    <section class="confirm-card">
        <div class="confirm-card__icon"><i class="bi bi-bug-fill"></i></div>
        <h1 class="confirm-card__title">Si e' verificato un errore</h1>
        <p class="confirm-card__text">La richiesta non e' stata completata correttamente. Usa i dettagli sotto solo per debug e supporto tecnico.</p>

        @if (Model.ShowRequestId)
        {
            <div class="page-surface mt-4">
                <div class="detail-row">
                    <span class="detail-row__label">Request ID</span>
                    <span class="detail-row__value"><code>@Model.RequestId</code></span>
                </div>
            </div>
        }

        <div class="detail-list mt-4 text-start">
            <div class="detail-row">
                <span class="detail-row__label">Development mode</span>
                <span class="detail-row__value">Abilita l'ambiente Development solo in locale per vedere dettagli completi dell'eccezione.</span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Produzione</span>
                <span class="detail-row__value">Non abilitare Development in ambienti pubblici per evitare esposizione di dati sensibili.</span>
            </div>
        </div>
    </section>
</div>
