@using Microsoft.AspNetCore.Identity
@using MisureRicci.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    <li class="nav-item">
        <a class="nav-link text-gold" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="bi bi-person-circle me-1"></i> Ciao @(user?.NomeCompleto ?? User.Identity?.Name)!
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link text-muted">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-muted" asp-area="Identity" asp-page="/Account/Register">Registrati</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-gold" asp-area="Identity" asp-page="/Account/Login">Accedi</a>
    </li>
}
</ul>
