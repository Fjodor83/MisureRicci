@using Microsoft.AspNetCore.Identity
@using MisureRicci.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage" style="color: var(--sr-gold-light) !important;">
            <i class="bi bi-person-circle me-1"></i> Ciao @(user?.NomeCompleto ?? User.Identity?.Name)!
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link text-white" style="color: rgba(255,255,255,0.7) !important;"><i class="bi bi-box-arrow-right me-1"></i> Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">Registrati</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login" style="color: var(--sr-gold) !important;">Accedi</a>
    </li>
}
</ul>
