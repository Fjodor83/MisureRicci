@using Microsoft.AspNetCore.Identity
@using MisureRicci.Helpers
@inject SignInManager<MisureRicci.Models.ApplicationUser> SignInManager
@inject UserManager<MisureRicci.Models.ApplicationUser> UserManager
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home").Trim();
    var action = (ViewContext.RouteData.Values["action"]?.ToString() ?? "Index").Trim();
    var isSignedIn = SignInManager.IsSignedIn(User);
    var currentUser = isSignedIn ? await UserManager.GetUserAsync(User) : null;
    var initialsSource = currentUser?.NomeCompleto ?? currentUser?.UserName ?? "?";
    var initials = string.Concat(
        initialsSource
            .Split(' ', System.StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0])));

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "?";
    }

    var roleLabel = User.IsInRole("Admin")
        ? "Admin"
        : User.IsInRole("Manager")
            ? "Manager"
            : User.IsInRole("Sartoria")
                ? "Sartoria"
                : User.IsInRole("Boutique")
                    ? "Boutique"
                    : "Staff";
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Misure Ricci</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MisureRicci.styles.css" asp-append-version="true" />
</head>
<body class="theme-dark">
    <div id="page-loader" class="page-loader"></div>
    <div id="sidebar-overlay"></div>

    <div class="app-layout">
        <aside class="app-sidebar">
            <div class="sidebar-brand-panel">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="sidebar-brand-link">
                    <span class="sidebar-brand-mark">MR</span>
                    <span>
                        <span class="sidebar-brand-text">Misure Ricci</span>
                        <span class="sidebar-brand-sub">Tailoring business workspace</span>
                    </span>
                </a>
            </div>

            <div class="sidebar-section-label">Workspace</div>
            <nav class="sidebar-nav" aria-label="Menu laterale">
                <a class="sidebar-link" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="sidebar-link-icon"><i class="bi bi-grid-1x2-fill"></i></span>
                    <span>Dashboard</span>
                </a>
                <a class="sidebar-link" asp-area="" asp-controller="Clienti" asp-action="Index">
                    <span class="sidebar-link-icon"><i class="bi bi-people-fill"></i></span>
                    <span>Clienti</span>
                </a>
                <a class="sidebar-link" asp-area="" asp-controller="Measurements" asp-action="GlobalRegistry">
                    <span class="sidebar-link-icon"><i class="bi bi-rulers"></i></span>
                    <span>Registro Misure</span>
                </a>
                <a class="sidebar-link" asp-area="" asp-controller="Commissioni" asp-action="Index">
                    <span class="sidebar-link-icon"><i class="bi bi-journal-check"></i></span>
                    <span>Commissioni</span>
                </a>
            </nav>


            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <div class="sidebar-section-label">Configurazione</div>
                <nav class="sidebar-nav" aria-label="Menu laterale">
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="sidebar-link" asp-area="" asp-controller="Negozi" asp-action="Index">
                            <span class="sidebar-link-icon"><i class="bi bi-shop"></i></span>
                            <span>Boutique</span>
                        </a>
                    }
                    <a class="sidebar-link" asp-area="" asp-controller="Utenti" asp-action="Index">
                        <span class="sidebar-link-icon"><i class="bi bi-person-badge-fill"></i></span>
                        <span>Staff</span>
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="sidebar-link" asp-area="" asp-controller="AdminMeasurementTypes" asp-action="Index">
                            <span class="sidebar-link-icon"><i class="bi bi-sliders2"></i></span>
                            <span>Tipologie Dinamiche</span>
                        </a>
                        <a class="sidebar-link" asp-area="" asp-controller="AdminFabrics" asp-action="Index">
                            <span class="sidebar-link-icon"><i class="bi bi-columns-gap"></i></span>
                            <span>Tipologie Tessuti</span>
                        </a>
                    }
                </nav>
            }

        </aside>

        <div class="app-content">
            <header class="app-header">
                <div class="header-meta">
                    <button class="hamburger-btn" id="hamburgerBtn" type="button" aria-label="Apri menu">
                        <i class="bi bi-list"></i>
                    </button>
                    <div>
                        <div class="header-kicker">Workspace</div>
                        <div class="header-title">@controller</div>
                    </div>
                </div>

                <div class="header-tools">
                    <button id="themeToggleBtn" type="button" class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center header-theme-toggle" title="Cambia tema">
                        <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                    </button>
                    <div class="header-chip d-none d-md-grid">
                        <span class="header-chip__label">Oggi</span>
                        <span class="header-chip__value">@DateTime.Now.ToString("dd MMM yyyy")</span>
                    </div>

                    @if (isSignedIn)
                    {
                        <div class="header-profile">
                            <div class="header-profile__avatar">@initials</div>
                            <div class="header-profile__body">
                                <strong>@(currentUser?.NomeCompleto ?? currentUser?.UserName)</strong>
                                <span>@(currentUser?.Email ?? roleLabel)</span>
                            </div>
                            <span class="status-pill status-pill--accent">@roleLabel</span>
                        </div>
                                <a href="/Identity/Account/Manage/ChangePassword"
                                    class="btn btn-outline-gold btn-sm"
                           title="Cambia password">
                            <i class="bi bi-key-fill"></i>
                        </a>
                        <form asp-area="Identity"
                              asp-page="/Account/Logout"
                              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                              method="post">
                            <button type="submit" class="btn btn-outline-secondary btn-sm header-logout" title="Esci">
                                <i class="bi bi-box-arrow-right"></i>
                            </button>
                        </form>
                    }
                </div>
            </header>

            <div class="main-container">
                <main role="main" class="page-shell">
                    @RenderBody()
                </main>
            </div>

            <footer class="app-footer d-none d-md-block">
                <div class="footer-container">
                    <div class="footer-grid">
                        <div class="footer-column-brand">
                            <div class="footer-brand-wrap">
                                <div class="footer-mark">MR</div>
                                <div>
                                    <div class="footer-brand-name">Misure Ricci</div>
                                    <div class="footer-brand-tag">Master Tailor Workspace</div>
                                </div>
                            </div>
                            <p class="footer-description">
                                Piattaforma esclusiva per la gestione della sartoria su misura e l'eccellenza artigianale italiana.
                            </p>
                        </div>

                        <div class="footer-column">
                            <h5 class="footer-heading">Workspace</h5>
                            <ul class="footer-list">
                                <li><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
                                <li><a asp-controller="Clienti" asp-action="Index">Anagrafica Clienti</a></li>
                                <li><a asp-controller="Measurements" asp-action="GlobalRegistry">Registro Misure</a></li>
                                <li><a asp-controller="Commissioni" asp-action="Index">Ordini & Commissioni</a></li>
                            </ul>
                        </div>

                        <div class="footer-column">
                            <h5 class="footer-heading">Supporto</h5>
                            <ul class="footer-list">
                                <li><a asp-controller="Home" asp-action="AiutoInfo">Aiuto/Info</a></li>
                                <li><a asp-controller="Home" asp-action="UserGuide">Guida all'uso</a></li>
                                <li><a asp-controller="Home" asp-action="TailoringStandards">Standard Sartoriali</a></li>
                                <li><a asp-controller="Home" asp-action="TechnicalSupport">Assistenza Tecnica</a></li>
                                <li><a asp-controller="Home" asp-action="ActivityLog">Log Attività</a></li>
                            </ul>
                        </div>

                        <div class="footer-column-status">
                            <h5 class="footer-heading">Sistema</h5>
                            <div class="footer-status-pill">
                                <span class="status-indicator"></span>
                                <span>Sistema Online</span>
                            </div>
                            <div class="footer-meta">
                                <span>Versione 3.0.4</span>
                                <span>&copy; 2026 Stefano Ricci S.p.A.</span>
                            </div>
                        </div>
                    </div>

                    <div class="footer-bottom-bar">
                        <div class="footer-legal">
                            <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                            <span class="dot-separator"></span>
                            <a asp-controller="Home" asp-action="TermsOfService">Termini di Servizio</a>
                            <span class="dot-separator"></span>
                            <a asp-controller="Home" asp-action="SecurityStandards">Standard di Sicurezza</a>
                        </div>
                        <div class="footer-signature">
                            Eccellenza Italiana <i class="bi bi-patch-check-fill text-gold ms-1"></i>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <nav class="mobile-bottom-nav d-md-none" aria-label="Navigazione mobile">
        <div class="mobile-nav-item @(controller == "Home" ? "active" : "")">
            <a asp-controller="Home" asp-action="Index">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Home</span>
            </a>
        </div>
        <div class="mobile-nav-item @(controller == "Clienti" ? "active" : "")">
            <a asp-controller="Clienti" asp-action="Index">
                <i class="bi bi-people-fill"></i>
                <span>Clienti</span>
            </a>
        </div>
        <div class="mobile-nav-primary">
            <button type="button" class="btn-mobile-primary" id="mobileQuickActionBtn">
                <i class="bi bi-plus-lg"></i>
            </button>
        </div>
        <div class="mobile-nav-item @(controller == "Commissioni" ? "active" : "")">
            <a asp-controller="Commissioni" asp-action="Index">
                <i class="bi bi-journal-check"></i>
                <span>Ordini</span>
            </a>
        </div>
        <div class="mobile-nav-item @(controller == "Measurements" ? "active" : "")">
            <a asp-controller="Measurements" asp-action="GlobalRegistry">
                <i class="bi bi-rulers"></i>
                <span>Misure</span>
            </a>
        </div>
    </nav>

    <script nonce="@HttpContextAccessor.GetNonce()" src="~/lib/jquery/dist/jquery.min.js"></script>

    <script nonce="@HttpContextAccessor.GetNonce()" src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script nonce="@HttpContextAccessor.GetNonce()" src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
