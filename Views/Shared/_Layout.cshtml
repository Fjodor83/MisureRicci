<!DOCTYPE html>
<html lang="it">
<head>
    @using Microsoft.AspNetCore.Identity
    @inject SignInManager<MisureRicci.Models.ApplicationUser> SignInManager
    @inject UserManager<MisureRicci.Models.ApplicationUser> UserManager
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - STEFANO RICCI Misure</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- DevExpress Fluent SaaS Themes -->
    <link id="dx-theme-light" rel="stylesheet" href="https://cdn3.devexpress.com/jslib/23.2.5/css/dx.fluent.saas.light.css" disabled />
    <link id="dx-theme-dark" rel="stylesheet" href="https://cdn3.devexpress.com/jslib/23.2.5/css/dx.fluent.saas.dark.css" />
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MisureRicci.styles.css" asp-append-version="true" />
</head>
<body class="dx-viewport theme-dark">
    <!-- Page Load Indicator -->
    <div id="page-loader"></div>
    <!-- Mobile Sidebar Overlay -->
    <div id="sidebar-overlay"></div>

    <div class="app-layout">
        <!-- Premium Sidebar -->
        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <span class="sidebar-brand-text">STEFANO RICCI</span>
                    <span class="sidebar-brand-sub">Sartoria Globale</span>
                </a>
            </div>
            
            <nav class="sidebar-nav">
                <a class="sidebar-link" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i> SaaS Dashboard
                </a>
                <a class="sidebar-link" asp-area="" asp-controller="Clienti" asp-action="Index">
                    <i class="bi bi-people-fill"></i> Clienti & Misure
                </a>
                <a class="sidebar-link" asp-area="" asp-controller="Commesse" asp-action="Index">
                    <i class="bi bi-journal-check"></i> Commesse
                </a>
                <a class="sidebar-link" asp-area="" asp-controller="Negozi" asp-action="Index">
                    <i class="bi bi-shop"></i> Boutique Network
                </a>
                <a class="sidebar-link" asp-area="" asp-controller="Utenti" asp-action="Index">
                    <i class="bi bi-person-badge-fill"></i> Staff SaaS
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a class="sidebar-link" asp-area="" asp-controller="AdminMeasurementTypes" asp-action="Index">
                        <i class="bi bi-sliders2"></i> Tipologie Dinamiche
                    </a>
                }
            </nav>
            
            <div class="mt-auto p-4 border-top border-gold-dim text-center">
                <p class="text-muted small font-cinzel letter-spacing-2 mb-2">Theme Engine</p>
                <div class="theme-switch-wrapper justify-content-center">
                    <button class="theme-switch-btn" id="themeToggleBtn" title="Toggle Theme">
                        <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                    </button>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="app-content">
            <header class="app-header">
                <div>
                    <button class="hamburger-btn" id="hamburgerBtn" aria-label="Menu"><i class="bi bi-list"></i></button>
                    <span class="text-muted small text-uppercase letter-spacing-1 d-none d-md-inline">Workspace / <strong>@ViewContext.RouteData.Values["controller"]</strong></span>
                </div>
                <div class="d-flex align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        var _currentUser = await UserManager.GetUserAsync(User);
                        var _initials = string.Concat((_currentUser?.NomeCompleto ?? _currentUser?.UserName ?? "?").Split(' ', System.StringSplitOptions.RemoveEmptyEntries).Take(2).Select(s => char.ToUpperInvariant(s[0])));
                        var _isAdmin = User.IsInRole("Admin");
                        <span class="badge @(_isAdmin ? "bg-gold text-dark" : "bg-success") me-3">
                            <i class="bi @(_isAdmin ? "bi-shield-lock-fill" : "bi-person-check-fill")"></i>&nbsp;@(_isAdmin ? "ADMIN" : "STAFF")
                        </span>
                        <div class="rounded-circle bg-dark border border-gold d-flex align-items-center justify-content-center" style="width:40px;height:40px;" title="@(_currentUser?.NomeCompleto ?? _currentUser?.Email)">
                            <span class="font-cinzel" style="font-size:0.70rem;color:var(--sr-gold);font-weight:700;">@_initials</span>
                        </div>
                    }
                </div>
            </header>
            
            <div class="main-container">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
            
            <footer class="footer mt-auto">
                <div class="container text-center text-uppercase letter-spacing-2 fw-bold">
                    &copy; 2026 - STEFANO RICCI Misure SaaS UI Premium
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
