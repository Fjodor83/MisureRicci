@model MisureRicci.Models.ViewModels.LegacyMeasurementDeleteViewModel

@{
    ViewData["Title"] = "Elimina " + Model.TipoMisura;
}

<div class="confirm-shell">
    <section class="confirm-card">
        <div class="confirm-card__icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <h1 class="confirm-card__title">Elimina misura @Model.TipoMisura</h1>
        <p class="confirm-card__text">
            Stai per eliminare la misura dal profilo cliente. Il record verra' rimosso insieme al relativo tracciamento
            storico e l'operazione non e' reversibile.
        </p>

        <form asp-action="Delete" method="post" class="form-actions justify-content-center mt-4">
            <input asp-for="Id" type="hidden" />
            <input asp-for="TipoMisura" type="hidden" />
            <input asp-for="RegistryId" type="hidden" />
            <button type="submit" class="btn btn-danger">Conferma eliminazione</button>
            <a asp-controller="Clienti" asp-action="Details" asp-route-id="@Model.ClienteId" class="btn btn-outline-secondary">Annulla</a>
        </form>
    </section>
</div>
