@model MisureRicci.Models.ViewModels.LegacyMeasurementDetailsViewModel

@{
    ViewData["Title"] = "Dettagli " + Model.TipoMisura;
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Legacy measurement</span>
        <h1 class="page-title">@Model.TipoMisura.ToUpper()</h1>
        <p class="page-subtitle">Dettaglio completo del record legacy associato a @Model.ClienteNome.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Edit" asp-route-id="@Model.Id" asp-route-tipoMisura="@Model.TipoMisura" class="btn btn-primary">Modifica</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" asp-route-tipoMisura="@Model.TipoMisura" class="btn btn-danger">Elimina</a>
        <a asp-controller="Clienti" asp-action="Details" asp-route-id="@Model.ClienteId" class="btn btn-outline-secondary">Torna al cliente</a>
    </div>
</section>

<div class="detail-stack">
    <article class="detail-card">
        <div class="detail-grid">
            <div class="detail-row">
                <span class="detail-row__label">Cliente</span>
                <span class="detail-row__value">@Model.ClienteNome</span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Data creazione</span>
                <span class="detail-row__value">@Model.CreatedAt.ToString("f")</span>
            </div>
        </div>
    </article>

    <article class="detail-card">
        <div class="detail-card__header">
            <div>
                <h2 class="detail-card__title">Valori misurati</h2>
                <p class="detail-card__subtitle">Lettura strutturata della scheda legacy.</p>
            </div>
        </div>
        @if (Model.Sections.Any())
        {
            <div class="detail-grid">
                @foreach (var measurementSection in Model.Sections)
                {
                    <div class="detail-list">
                        <div class="detail-row">
                            <span class="detail-row__label">@measurementSection.Title</span>
                        </div>
                        @foreach (var field in measurementSection.Fields)
                        {
                            <div class="detail-row">
                                <span class="detail-row__label">@field.DisplayName</span>
                                <span class="detail-row__value">@field.Value</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="detail-grid">
                @foreach (var field in Model.Fields)
                {
                    <div class="detail-row">
                        <span class="detail-row__label">@field.DisplayName</span>
                        <span class="detail-row__value">@field.Value</span>
                    </div>
                }
            </div>
        }
    </article>

    @if (!string.IsNullOrEmpty(Model.Notes))
    {
        <article class="detail-card">
            <div class="detail-card__header">
                <div>
                    <h2 class="detail-card__title">Note</h2>
                </div>
            </div>
            <p class="mb-0">@Model.Notes</p>
        </article>
    }
</div>
