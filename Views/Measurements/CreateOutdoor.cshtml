@model MisureRicci.Models.OutdoorMeasurement

@{
    ViewData["Title"] = "Misure Outdoor - " + ViewBag.ClienteNome;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-end mb-3">
            <h1 class="sr-title mb-0">INSERIMENTO MISURE OUTDOOR</h1>
            <span class="sr-gold small text-uppercase fw-bold">Cliente: @ViewBag.ClienteNome</span>
        </div>
        
        <form asp-action="CreateOutdoor" method="post" class="mt-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="ClienteId" />

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="OrderId" class="form-label sr-gold">NUMERO ORDINE (Opzionale)</label>
                    <input asp-for="OrderId" class="form-control" placeholder="SR-XXXXX" />
                    <span asp-validation-for="OrderId" class="text-danger"></span>
                </div>
            </div>

            <hr class="my-4 border-gold" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Torace" class="form-label"></label>
                    <input asp-for="Torace" class="form-control" type="number" step="0.5" />
                    <span asp-validation-for="Torace" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Spalle" class="form-label"></label>
                    <input asp-for="Spalle" class="form-control" type="number" step="0.5" />
                    <span asp-validation-for="Spalle" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Manica" class="form-label"></label>
                    <input asp-for="Manica" class="form-control" type="number" step="0.5" />
                    <span asp-validation-for="Manica" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Lunghezza" class="form-label"></label>
                    <input asp-for="Lunghezza" class="form-control" type="number" step="0.5" />
                    <span asp-validation-for="Lunghezza" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Fit" class="form-label"></label>
                    <select asp-for="Fit" class="form-control">
                        <option value="Regular">Regular Fit</option>
                        <option value="Slim">Slim Fit</option>
                        <option value="Comfort">Comfort Fit</option>
                    </select>
                    <span asp-validation-for="Fit" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <a asp-action="Index" asp-route-clienteId="@Model.ClienteId" class="btn btn-outline-secondary me-md-2">ANNULLA</a>
                <button type="submit" class="btn btn-primary px-5">SALVA MISURE</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
