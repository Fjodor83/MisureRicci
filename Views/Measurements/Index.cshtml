@{
    ViewData["Title"] = "Dashboard Misure - " + ViewBag.ClienteNome;
    int clienteId = ViewBag.ClienteId;
    var dynamicTypes = ViewBag.DynamicMeasurementTypes as List<MisureRicci.Models.MeasurementType> ?? new();
}

<div class="text-center mb-5">
    <h1 class="sr-title">GESTIONALE MISURE</h1>
    <p class="sr-gold text-uppercase letter-spacing-2">Seleziona la categoria di abbigliamento per <strong>@ViewBag.ClienteNome</strong></p>
</div>

<div class="row g-4">
    @if (!dynamicTypes.Any())
    {
        <div class="col-12">
            <div class="card p-5 text-center">
                <i class="bi bi-sliders2 fs-1 sr-gold opacity-75 mb-3"></i>
                <p class="text-muted mb-0">Nessuna tipologia attiva disponibile. Verifica il seed iniziale o la configurazione admin.</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var type in dynamicTypes)
        {
            <div class="col-md-4">
                <a asp-controller="DynamicMeasurements" asp-action="Create" asp-route-clienteId="@clienteId" asp-route-typeId="@type.Id" class="text-decoration-none">
                    <div class="card category-card h-100 card-glow">
                        <i class="bi bi-sliders2-vertical sr-gold"></i>
                        <h3 class="sr-title small">@type.Nome.ToUpper()</h3>
                        <hr class="border-gold opacity-50 mx-4" />
                        <p class="text-muted small px-3">@type.Descrizione</p>
                    </div>
                </a>
            </div>
        }
    }
</div>


<div class="text-center mt-5 mb-5">
    <a asp-controller="Clienti" asp-action="Details" asp-route-id="@clienteId" class="btn btn-outline-secondary px-5">TORNA AL PROFILO CLIENTE</a>
</div>
