@model MisureRicci.Models.ViewModels.MeasurementsDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Misure - " + Model.ClienteNome;
    int clienteId = Model.ClienteId;
    var dynamicTypes = Model.DynamicMeasurementTypes;
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Measurement workspace</span>
        <h1 class="page-title">Seleziona una tipologia</h1>
        <p class="page-subtitle">
            Cliente: <strong>@Model.ClienteNome</strong>. Scegli la categoria di misura e apri subito il form piu' adatto.
        </p>
    </div>
    <div class="page-actions">
        <a asp-controller="Clienti" asp-action="Details" asp-route-id="@clienteId" class="btn btn-outline-secondary">Torna al cliente</a>
    </div>
</section>

@if (!dynamicTypes.Any())
{
    <section class="empty-state">
        <div class="empty-state__icon"><i class="bi bi-sliders2"></i></div>
        <h2 class="empty-state__title">Nessuna tipologia attiva</h2>
        <p class="empty-state__text">Verifica la configurazione amministrativa delle tipologie dinamiche prima di procedere.</p>
    </section>
}
else
{
    <section class="feature-grid">
        @foreach (var type in dynamicTypes)
        {
            <a asp-controller="DynamicMeasurements"
               asp-action="Create"
               asp-route-clienteId="@clienteId"
               asp-route-typeId="@type.Id"
               class="feature-card">
                <div class="feature-card__icon"><i class="bi bi-sliders2-vertical"></i></div>
                <div>
                    <h2 class="feature-card__title">@type.Nome</h2>
                    <p class="feature-card__text">@type.Descrizione</p>
                </div>
                <div class="feature-card__actions">
                    <span class="btn btn-outline-gold">Apri form</span>
                </div>
            </a>
        }
    </section>
}
