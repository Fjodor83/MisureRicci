@model MisureRicci.Models.ViewModels.MeasurementsGlobalRegistryViewModel

@{
    ViewData["Title"] = "Registro Misure - " + Model.Categoria;
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Measurement archive</span>
        <h1 class="page-title">Registro sartoriale</h1>
        <p class="page-subtitle">Archivio globale per la categoria <strong>@Model.Categoria</strong>.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Clienti" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-people-fill me-2"></i>Apri clienti
        </a>
    </div>
</section>

<section class="data-table-card">
    <div class="table-toolbar">
        <div>
            <h2 class="detail-card__title">Cronologia misure</h2>
            <div class="toolbar-meta">Consultazione filtrata per categoria con accesso diretto alle schede.</div>
        </div>
        <span class="toolbar-chip">@Model.Items.Count() record</span>
    </div>

    @if (Model.Items.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Data registrazione</th>
                        <th>Cliente</th>
                        <th>Codice</th>
                        <th>Articolo</th>
                        <th class="text-end">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.DataCreazione.ToString("dd MMM yyyy HH:mm")</td>
                            <td>@item.Cliente?.Nome @item.Cliente?.Cognome</td>
                            <td><span class="table-code">@item.Cliente?.ClientCode</span></td>
                            <td>@item.TipoMisura.ToUpper()</td>
                            <td class="text-end">
                                <a asp-controller="Measurements"
                                   asp-action="Details"
                                   asp-route-id="@item.RecordId"
                                   asp-route-tipoMisura="@item.TipoMisura"
                                   asp-route-registryId="@item.Id"
                                   class="btn btn-sm btn-outline-gold">Apri scheda</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-4">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="GlobalRegistry" asp-route-filter="@Model.Filter" asp-route-page="@(Model.CurrentPage - 1)">Precedente</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="GlobalRegistry" asp-route-filter="@Model.Filter" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="GlobalRegistry" asp-route-filter="@Model.Filter" asp-route-page="@(Model.CurrentPage + 1)">Successiva</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state__icon"><i class="bi bi-journal-x"></i></div>
            <h3 class="empty-state__title">Nessuna misura registrata</h3>
            <p class="empty-state__text">Aggiungi una misura da anagrafica cliente per alimentare il registro.</p>
            <a asp-controller="Clienti" asp-action="Index" class="btn btn-outline-gold">Vai ai clienti</a>
        </div>
    }
</section>
