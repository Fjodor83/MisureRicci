@model MisureRicci.Models.ViewModels.MeasurementsGlobalRegistryViewModel

@{
    ViewData["Title"] = "Registro Misure - " + Model.Categoria;
}

<div class="d-flex justify-content-between align-items-center mb-4 animate__animated animate__fadeInDown">
    <div>
        <h1 class="page-title">REGISTRO SARTORIALE</h1>
        <p class="page-subtitle mt-2 mb-0">Archivio globale per: @Model.Categoria</p>
    </div>
    <a asp-controller="Clienti" asp-action="Index" class="btn btn-primary"><i class="bi bi-person-plus-fill me-2"></i> NUOVA MISURA</a>
</div>

<div class="card overflow-hidden animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
    <div class="card-header bg-transparent border-bottom border-gold-dim">
        <h3 class="sr-title small mb-0"><i class="bi bi-journal-text me-2"></i> CRONOLOGIA MISURE</h3>
    </div>
    <div class="table-responsive">
        @if (Model.Items.Any())
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Data Registrazione</th>
                        <th>Cliente</th>
                        <th>Codice</th>
                        <th>Articolo</th>
                        <th class="text-end pe-4">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items) {
                    <tr style="transition: all 0.3s ease;">
                        <td class="ps-4 text-muted small">@item.DataCreazione.ToString("dd MMM yyyy HH:mm")</td>
                        <td class="fw-bold font-cinzel">@item.Cliente?.Nome @item.Cliente?.Cognome</td>
                        <td><span class="badge rounded-pill fw-normal" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(212, 175, 55, 0.3); color: var(--sr-gold-light);">@item.Cliente?.ClientCode</span></td>
                        <td>
                            <i class="bi bi-rulers me-2 sr-gold opacity-50"></i> 
                            @item.TipoMisura.ToUpper()
                        </td>
                        <td class="text-end pe-4">
                            <a asp-controller="Measurements" asp-action="Details" asp-route-id="@item.RecordId" asp-route-tipoMisura="@item.TipoMisura" asp-route-registryId="@item.Id" class="btn btn-sm btn-outline-gold" title="Dettaglio Misura"><i class="bi bi-eye"></i> VEDI</a>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-transparent border-top border-gold-dim py-3">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link bg-transparent border-gold-dim text-gold" asp-action="GlobalRegistry" asp-route-filter="@Model.Filter" asp-route-page="@(Model.CurrentPage - 1)">Precedente</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link @(i == Model.CurrentPage ? "bg-gold text-navy" : "bg-transparent border-gold-dim text-gold")" asp-action="GlobalRegistry" asp-route-filter="@Model.Filter" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link bg-transparent border-gold-dim text-gold" asp-action="GlobalRegistry" asp-route-filter="@Model.Filter" asp-route-page="@(Model.CurrentPage + 1)">Successiva</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
        }
        else
        {
            <div class="py-5 text-center">
                <i class="bi bi-journal-x fs-1 text-muted opacity-50"></i>
                <p class="text-muted mt-3 font-cinzel small letter-spacing-2">NESSUNA MISURA REGISTRATA</p>
                <a asp-controller="Clienti" asp-action="Index" class="btn btn-outline-gold btn-sm mt-2">AGGIUNGI PRIMA MISURA</a>
            </div>
        }
    </div>
</div>

<style>
    .pagination .page-link:hover {
        background-color: var(--sr-gold-dim) !important;
        color: white !important;
    }
    .pagination .page-item.active .page-link {
        background-color: var(--sr-gold) !important;
        border-color: var(--sr-gold) !important;
        color: var(--sr-navy-deep) !important;
        font-weight: bold;
    }
</style>
