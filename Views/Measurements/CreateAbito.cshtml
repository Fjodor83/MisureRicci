@model MisureRicci.Models.AbitoCompletoMeasurement

@{
    ViewData["Title"] = "Misure Abito Completo - " + ViewBag.ClienteNome;
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="d-flex justify-content-between align-items-end mb-3">
            <h1 class="sr-title mb-0">INSERIMENTO ABITO COMPLETO</h1>
            <span class="sr-gold small text-uppercase fw-bold">Cliente: @ViewBag.ClienteNome</span>
        </div>
        
        <form asp-action="CreateAbito" method="post" class="mt-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="ClienteId" />

            <div class="card p-4 mb-4">
                <label asp-for="OrderId" class="form-label sr-gold">NUMERO ORDINE</label>
                <input asp-for="OrderId" class="form-control" placeholder="SR-XXXXX" />
                <span asp-validation-for="OrderId" class="text-danger"></span>
            </div>

            <div class="row">
                <!-- GIACCA PART -->
                <div class="col-md-6">
                    <div class="card p-4 h-100">
                        <h3 class="sr-title small mb-4">PARTE GIACCA</h3>
                        <div class="mb-3">
                            <label asp-for="Giacca.Spalle" class="form-label">Spalle</label>
                            <input asp-for="Giacca.Spalle" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Giacca.Spalle" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Giacca.Torace" class="form-label">Torace</label>
                            <input asp-for="Giacca.Torace" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Giacca.Torace" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Giacca.Vita" class="form-label">Vita</label>
                            <input asp-for="Giacca.Vita" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Giacca.Vita" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Giacca.Manica" class="form-label">Manica</label>
                            <input asp-for="Giacca.Manica" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Giacca.Manica" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Giacca.Lunghezza" class="form-label">Lunghezza</label>
                            <input asp-for="Giacca.Lunghezza" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Giacca.Lunghezza" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- PANTALONE PART -->
                <div class="col-md-6">
                    <div class="card p-4 h-100">
                        <h3 class="sr-title small mb-4">PARTE PANTALONE</h3>
                        <div class="mb-3">
                            <label asp-for="Pantalone.Vita" class="form-label">Vita</label>
                            <input asp-for="Pantalone.Vita" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Pantalone.Vita" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Pantalone.Bacino" class="form-label">Bacino</label>
                            <input asp-for="Pantalone.Bacino" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Pantalone.Bacino" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Pantalone.Cavallo" class="form-label">Cavallo</label>
                            <input asp-for="Pantalone.Cavallo" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Pantalone.Cavallo" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Pantalone.InternoGamba" class="form-label">Interno Gamba</label>
                            <input asp-for="Pantalone.InternoGamba" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Pantalone.InternoGamba" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Pantalone.Fondo" class="form-label">Fondo</label>
                            <input asp-for="Pantalone.Fondo" class="form-control" type="number" step="0.5" />
                            <span asp-validation-for="Pantalone.Fondo" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card p-4 my-4">
                <label asp-for="Notes" class="form-label sr-gold">NOTE AGGIUNTIVE</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end mb-5">
                <a asp-action="Index" asp-route-clienteId="@Model.ClienteId" class="btn btn-outline-secondary me-md-2">ANNULLA</a>
                <button type="submit" class="btn btn-primary px-5">SALVA ABITO COMPLETO</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
