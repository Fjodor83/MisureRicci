@model MisureRicci.Models.Negozio
@{ ViewData["Title"] = "Elimina Negozio"; }
<div class="card p-5 text-center mx-auto" style="max-width: 600px;">
    <h1 class="text-danger mb-4"><i class="bi bi-exclamation-triangle-fill"></i> ELIMINA NEGOZIO</h1>
    <p class="fs-5 mb-4">Sei sicuro di voler eliminare il negozio <strong>@Model.Nome</strong>?<br/>L'operazione non è reversibile.</p>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex justify-content-center gap-3">
            <button type="submit" class="btn btn-danger btn-lg">Conferma Eliminazione</button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Annulla</a>
        </div>
    </form>
</div>
