@model MisureRicci.Models.Negozio

@{
    ViewData["Title"] = "Elimina Negozio";
}

<div class="confirm-shell">
    <section class="confirm-card">
        <div class="confirm-card__icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <h1 class="confirm-card__title">Elimina negozio</h1>
        <p class="confirm-card__text">
            Stai per eliminare la sede <strong>@Model.Nome</strong>. L'operazione non e' reversibile.
        </p>

        <form asp-action="Delete" class="form-actions justify-content-center mt-4">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Conferma eliminazione</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
        </form>
    </section>
</div>
