@model MisureRicci.Models.Negozio

@{
    ViewData["Title"] = "Modifica Negozio";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Network management</span>
        <h1 class="page-title">Modifica negozio</h1>
        <p class="page-subtitle">Aggiorna dati, stato operativo e informazioni logistiche della sede.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Torna alla lista</a>
    </div>
</section>

<form asp-action="Edit" class="form-shell">
    <section class="form-section">
        <div asp-validation-summary="All" class="alert alert-danger"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="CodiceNegozio" class="form-label"></label>
                <input asp-for="CodiceNegozio" class="form-control" />
                <span asp-validation-for="CodiceNegozio" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Indirizzo" class="form-label"></label>
                <input asp-for="Indirizzo" class="form-control" />
                <span asp-validation-for="Indirizzo" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Citta" class="form-label"></label>
                <input asp-for="Citta" class="form-control" />
                <span asp-validation-for="Citta" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Paese" class="form-label"></label>
                <input asp-for="Paese" class="form-control" />
                <span asp-validation-for="Paese" class="text-danger"></span>
            </div>
        </div>

        <div class="form-check form-switch mt-4">
            <input asp-for="Attivo" class="form-check-input" />
            <label asp-for="Attivo" class="form-check-label"></label>
        </div>
    </section>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Salva</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</form>
