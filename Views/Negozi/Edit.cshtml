@model MisureRicci.Models.Negozio
@{ ViewData["Title"] = "Modifica Negozio"; }
<div class="card p-4 mx-auto" style="max-width: 600px;">
    <h1 class="sr-title mb-4">MODIFICA NEGOZIO</h1>
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        <div class="mb-3"><label asp-for="Nome" class="form-label sr-gold small text-uppercase"></label><input asp-for="Nome" class="form-control" /></div>
        <div class="mb-3"><label asp-for="CodiceNegozio" class="form-label sr-gold small text-uppercase"></label><input asp-for="CodiceNegozio" class="form-control" /></div>
        <div class="mb-3"><label asp-for="Indirizzo" class="form-label sr-gold small text-uppercase"></label><input asp-for="Indirizzo" class="form-control" /></div>
        <div class="mb-3"><label asp-for="Citta" class="form-label sr-gold small text-uppercase"></label><input asp-for="Citta" class="form-control" /></div>
        <div class="mb-3"><label asp-for="Paese" class="form-label sr-gold small text-uppercase"></label><input asp-for="Paese" class="form-control" /></div>
        <div class="mb-3 form-check"><input asp-for="Attivo" class="form-check-input" /><label asp-for="Attivo" class="form-check-label sr-gold small text-uppercase"></label></div>
        <div class="mt-4"><button type="submit" class="btn btn-primary">Salva</button><a asp-action="Index" class="btn btn-outline-secondary ms-2">Annulla</a></div>
    </form>
</div>
