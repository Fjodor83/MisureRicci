@model MisureRicci.Models.Negozio

@{
    ViewData["Title"] = "Nuovo Negozio";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Network management</span>
        <h1 class="page-title">Inserisci nuovo negozio</h1>
        <p class="page-subtitle">Registra una nuova sede operativa con dati geografici e stato di attivazione.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
    </div>
</section>

<form asp-action="Create" method="post" class="form-shell">
    <section class="form-section">
        <div asp-validation-summary="All"></div>

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Nome" class="form-label">Nome</label>
                <input asp-for="Nome" class="form-control" placeholder="Es. Flagship Store Milan" required />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="CodiceNegozio" class="form-label">Codice Negozio</label>
                <input asp-for="CodiceNegozio" class="form-control" placeholder="Es. SR-MI-01" />
                <span asp-validation-for="CodiceNegozio" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Citta" class="form-label">Città</label>
                <input asp-for="Citta" class="form-control" required />
                <span asp-validation-for="Citta" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Paese" class="form-label">Paese</label>
                <input asp-for="Paese" class="form-control" required />
                <span asp-validation-for="Paese" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Indirizzo" class="form-label">Indirizzo</label>
                <textarea asp-for="Indirizzo" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Indirizzo" class="text-danger"></span>
            </div>
        </div>

        <div class="form-check form-switch mt-4">
            <input class="form-check-input" type="checkbox" asp-for="Attivo">
            <label class="form-check-label" asp-for="Attivo">Negozio attivo</label>
        </div>
    </section>

    <div class="form-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Annulla</a>
        <button type="submit" class="btn btn-primary">Salva negozio</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
