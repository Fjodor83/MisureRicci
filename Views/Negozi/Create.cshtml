@model MisureRicci.Models.Negozio

@{
    ViewData["Title"] = "Nuovo Negozio";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h1 class="sr-title">INSERIMENTO NUOVO NEGOZIO</h1>
        
        <form asp-action="Create" method="post" class="mt-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="card p-4 mb-4">
                <div class="mb-3">
                    <label asp-for="Nome" class="form-label sr-gold">NOME NEGOZIO</label>
                    <input asp-for="Nome" class="form-control" placeholder="Es: Flagship Store Milan" required />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CodiceNegozio" class="form-label sr-gold">CODICE NEGOZIO</label>
                    <input asp-for="CodiceNegozio" class="form-control" placeholder="Es: SR-MI-01" />
                    <span asp-validation-for="CodiceNegozio" class="text-danger"></span>
                </div>
            </div>

            <div class="card p-4 mb-4">
                <h3 class="sr-title small mb-4">LOCALIZZAZIONE</h3>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Citta" class="form-label sr-gold">CITTÀ</label>
                        <input asp-for="Citta" class="form-control" required />
                        <span asp-validation-for="Citta" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Paese" class="form-label sr-gold">PAESE</label>
                        <input asp-for="Paese" class="form-control" required />
                        <span asp-validation-for="Paese" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Indirizzo" class="form-label">INDIRIZZO COMPLETO</label>
                    <textarea asp-for="Indirizzo" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Indirizzo" class="text-danger"></span>
                </div>
            </div>

            <div class="form-check form-switch mb-4">
                <input class="form-check-input" type="checkbox" asp-for="Attivo">
                <label class="form-check-label text-white" asp-for="Attivo">Negozio Attivo</label>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <a asp-action="Index" class="btn btn-outline-secondary me-md-2">ANNULLA</a>
                <button type="submit" class="btn btn-primary px-5">SALVA NEGOZIO</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
