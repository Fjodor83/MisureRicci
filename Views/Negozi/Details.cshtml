@model MisureRicci.Models.Negozio

@{
    ViewData["Title"] = "Dettagli Negozio - " + Model.Nome;
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Network management</span>
        <h1 class="page-title">@Model.Nome</h1>
        <p class="page-subtitle">Scheda boutique con stato, codice e informazioni di localizzazione.</p>
    </div>
    <div class="page-actions">
        <span class="status-pill @(Model.Attivo ? "status-pill--success" : "status-pill--danger")">@(Model.Attivo ? "Operativo" : "Non operativo")</span>
        <a asp-action="Index" class="btn btn-outline-secondary">Torna alla lista</a>
    </div>
</section>

<div class="detail-grid">
    <article class="detail-card">
        <div class="detail-card__header">
            <div>
                <h2 class="detail-card__title">Informazioni principali</h2>
            </div>
        </div>
        <div class="detail-list">
            <div class="detail-row">
                <span class="detail-row__label">Nome boutique</span>
                <span class="detail-row__value">@Model.Nome</span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Codice negozio</span>
                <span class="detail-row__value"><span class="table-code">@Model.CodiceNegozio</span></span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Indirizzo</span>
                <span class="detail-row__value">@Model.Indirizzo</span>
            </div>
            <div class="detail-row">
                <span class="detail-row__label">Citta' / Paese</span>
                <span class="detail-row__value">@Model.Citta - @Model.Paese</span>
            </div>
        </div>
    </article>

    <article class="detail-card">
        <div class="detail-card__header">
            <div>
                <h2 class="detail-card__title">Stato operativo</h2>
                <p class="detail-card__subtitle">Sintesi rapida della disponibilita' della sede.</p>
            </div>
        </div>
        <div class="empty-state">
            <div class="empty-state__icon"><i class="bi bi-graph-up"></i></div>
            <h3 class="empty-state__title">Dashboard sede</h3>
            <p class="empty-state__text">La vista e' pronta per KPI e monitoraggio locale quando saranno disponibili dati dedicati.</p>
        </div>
    </article>
</div>
