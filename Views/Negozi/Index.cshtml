@model IEnumerable<MisureRicci.Models.Negozio>

@{
    ViewData["Title"] = "Gestione Negozi";
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-kicker">Network management</span>
        <h1 class="page-title">Rete boutique</h1>
        <p class="page-subtitle">Presidio di sedi, laboratori e stato operativo in un'unica lista amministrativa.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-shop me-2"></i>Nuova sede
        </a>
    </div>
</section>

<section class="data-table-card">
    <div class="table-toolbar">
        <div>
            <h2 class="detail-card__title">Boutique configurate</h2>
            <div class="toolbar-meta">Elenco sedi con stato e codice interno.</div>
        </div>
        <span class="toolbar-chip">@Model.Count() sedi</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Nome boutique</th>
                    <th>Citta'</th>
                    <th>Paese</th>
                    <th>Codice</th>
                    <th>Stato</th>
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Nome</td>
                        <td>@item.Citta</td>
                        <td>@item.Paese</td>
                        <td><span class="table-code">@item.CodiceNegozio</span></td>
                        <td><span class="status-pill @(item.Attivo ? "status-pill--success" : "status-pill--neutral")">@(item.Attivo ? "Attiva" : "Inattiva")</span></td>
                        <td class="text-end">
                            <div class="page-actions justify-content-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-gold">Dettagli</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Modifica</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
