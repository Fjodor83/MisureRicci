# Esclude file di configurazione locale e segreti
**/.env
**/appsettings.Development.json
**/appsettings.*.json
!**/appsettings.Production.json
**/secrets.*
**/*.pfx
**/*.pem
**/*.key

# Esclude cartelle di version control e IDE
**/.git/
**/.vs/
**/.vscode/
**/bin/
**/obj/

# Esclude file di documentazione e immagini non necessarie
**/*.md
**/*.png
**/*.jpg
**/.dockerignore
**/Dockerfile*
**/docker-compose*.yml
**/.editorconfig

# Esclude file temporanei e di log
**/*.log
**/logs/
**/*.tmp
**/*.swp